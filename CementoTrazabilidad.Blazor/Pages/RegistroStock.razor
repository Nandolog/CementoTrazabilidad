@page "/registro-stock"
@layout MainLayout
@attribute [Authorize(Roles = "Operario,Supervisor,Administrador")]
@using CementoTrazabilidad.Shared.DTOs
@using System.Net.Http.Json
@inject HttpClient Http
@inject ITurnoService TurnoService
@inject ILogger<RegistroStock> Logger
@inject IJSRuntime JS

<PageTitle>Registro de Stock de Palets - CementoTrazabilidad</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1><i class="fas fa-pallet me-2"></i>Control de Stock de Palets</h1>
            <p class="text-muted">Registro de stock inicial y final por turno (C32 y F40)</p>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Cargando...</p>
        </div>
    }
    else if (turnoActual == null)
    {
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle me-2"></i>
            No hay turno activo. Inicia un turno para registrar stock.
        </div>
    }
    else
    {
        <div class="row">
            <!-- Columna Izquierda: Formulario de Registro -->
            <div class="col-lg-6">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-edit me-2"></i>
                            @(registroExistente == null ? "Stock Inicial" : registroExistente.StockFinalC32.HasValue ? "Stock Registrado" : "Stock Final") - Turno @turnoActual.TurnoNumero
                        </h5>
                    </div>
                    <div class="card-body">
                        @if (registroExistente == null)
                        {
                            <!-- Formulario de Stock Inicial -->
                            <EditForm Model="@stockInicialDto" OnValidSubmit="@RegistrarStockInicial">
                                <DataAnnotationsValidator />
                                
                                <div class="alert alert-info mb-3">
                                    <i class="fas fa-info-circle me-2"></i>
                                    Registra el stock de palets al <strong>inicio del turno</strong>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">
                                            <i class="fas fa-box text-info me-1"></i> Stock Inicial C32
                                        </label>
                                        <InputNumber class="form-control form-control-lg" @bind-Value="stockInicialDto.StockInicialC32" 
                                                   disabled="@guardando" />
                                        <ValidationMessage For="@(() => stockInicialDto.StockInicialC32)" />
                                        <small class="form-text text-muted">Palets de C32 al inicio</small>
                                    </div>
                                    
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">
                                            <i class="fas fa-box text-success me-1"></i> Stock Inicial F40
                                        </label>
                                        <InputNumber class="form-control form-control-lg" @bind-Value="stockInicialDto.StockInicialF40" 
                                                   disabled="@guardando" />
                                        <ValidationMessage For="@(() => stockInicialDto.StockInicialF40)" />
                                        <small class="form-text text-muted">Palets de F40 al inicio</small>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Observaciones (Opcional)</label>
                                    <InputTextArea class="form-control" @bind-Value="stockInicialDto.ObservacionesInicio" 
                                                 rows="2" disabled="@guardando" 
                                                 placeholder="Ej: Stock heredado del turno anterior, ajustes realizados..."/>
                                </div>

                                <div class="d-grid">
                                    <button type="submit" class="btn btn-primary btn-lg" disabled="@guardando">
                                        @if (guardando)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                            <span>Guardando...</span>
                                        }
                                        else
                                        {
                                            <i class="fas fa-save me-2"></i>
                                            <span>Registrar Stock Inicial</span>
                                        }
                                    </button>
                                </div>
                            </EditForm>
                        }
                        else if (registroExistente.StockFinalC32.HasValue && registroExistente.StockFinalF40.HasValue)
                        {
                            <!-- Stock ya completado -->
                            <div class="alert alert-success">
                                <h5><i class="fas fa-check-circle me-2"></i>Stock Completo</h5>
                                <p class="mb-0">El stock inicial y final ya fueron registrados para este turno.</p>
                            </div>
                        }
                        else
                        {
                            <!-- Formulario de Stock Final -->
                            <EditForm Model="@stockFinalDto" OnValidSubmit="@RegistrarStockFinal">
                                <DataAnnotationsValidator />
                                
                                <div class="alert alert-warning mb-3">
                                    <i class="fas fa-flag-checkered me-2"></i>
                                    Registra el stock de palets al <strong>finalizar el turno</strong>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">
                                            <i class="fas fa-box text-info me-1"></i> Stock Final C32
                                        </label>
                                        <InputNumber class="form-control form-control-lg" @bind-Value="stockFinalDto.StockFinalC32" 
                                                   disabled="@guardando" />
                                        <ValidationMessage For="@(() => stockFinalDto.StockFinalC32)" />
                                        <small class="form-text text-muted">Inicial: @registroExistente.StockInicialC32</small>
                                    </div>
                                    
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">
                                            <i class="fas fa-box text-success me-1"></i> Stock Final F40
                                        </label>
                                        <InputNumber class="form-control form-control-lg" @bind-Value="stockFinalDto.StockFinalF40" 
                                                   disabled="@guardando" />
                                        <ValidationMessage For="@(() => stockFinalDto.StockFinalF40)" />
                                        <small class="form-text text-muted">Inicial: @registroExistente.StockInicialF40</small>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Observaciones de Cierre (Opcional)</label>
                                    <InputTextArea class="form-control" @bind-Value="stockFinalDto.ObservacionesFin" 
                                                 rows="2" disabled="@guardando" 
                                                 placeholder="Ej: Palets pendientes de retirar, observaciones finales..."/>
                                </div>

                                <div class="d-grid">
                                    <button type="submit" class="btn btn-warning btn-lg" disabled="@guardando">
                                        @if (guardando)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                            <span>Guardando...</span>
                                        }
                                        else
                                        {
                                            <i class="fas fa-flag-checkered me-2"></i>
                                            <span>Registrar Stock Final</span>
                                        }
                                    </button>
                                </div>
                            </EditForm>
                        }

                        @if (!string.IsNullOrEmpty(mensajeError))
                        {
                            <div class="alert alert-danger mt-3">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                @mensajeError
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(mensajeExito))
                        {
                            <div class="alert alert-success mt-3">
                                <i class="fas fa-check-circle me-2"></i>
                                @mensajeExito
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Columna Derecha: Resumen y EstadÝsticas -->
            <div class="col-lg-6">
                @if (registroExistente != null)
                {
                    <div class="card shadow mb-3">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0">
                                <i class="fas fa-chart-bar me-2"></i>Resumen del Turno
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row text-center mb-3">
                                <div class="col-md-6">
                                    <div class="card bg-light">
                                        <div class="card-body">
                                            <h6 class="text-info">C32</h6>
                                            <div class="row">
                                                <div class="col-6">
                                                    <small class="text-muted">Inicial</small>
                                                    <h4 class="mb-0">@registroExistente.StockInicialC32</h4>
                                                </div>
                                                <div class="col-6">
                                                    <small class="text-muted">Final</small>
                                                    <h4 class="mb-0">@(registroExistente.StockFinalC32?.ToString() ?? "-")</h4>
                                                </div>
                                            </div>
                                            @if (registroExistente.StockFinalC32.HasValue)
                                            {
                                                <hr />
                                                <p class="mb-0">
                                                    <strong>Producciˇn:</strong> 
                                                    <span class="badge @(registroExistente.ProduccionNetaC32 >= 0 ? "bg-success" : "bg-danger") fs-6">
                                                        @registroExistente.ProduccionNetaC32.ToString("+#;-#;0")
                                                    </span>
                                                </p>
                                            }
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-md-6">
                                    <div class="card bg-light">
                                        <div class="card-body">
                                            <h6 class="text-success">F40</h6>
                                            <div class="row">
                                                <div class="col-6">
                                                    <small class="text-muted">Inicial</small>
                                                    <h4 class="mb-0">@registroExistente.StockInicialF40</h4>
                                                </div>
                                                <div class="col-6">
                                                    <small class="text-muted">Final</small>
                                                    <h4 class="mb-0">@(registroExistente.StockFinalF40?.ToString() ?? "-")</h4>
                                                </div>
                                            </div>
                                            @if (registroExistente.StockFinalF40.HasValue)
                                            {
                                                <hr />
                                                <p class="mb-0">
                                                    <strong>Producciˇn:</strong> 
                                                    <span class="badge @(registroExistente.ProduccionNetaF40 >= 0 ? "bg-success" : "bg-danger") fs-6">
                                                        @registroExistente.ProduccionNetaF40.ToString("+#;-#;0")
                                                    </span>
                                                </p>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>

                            @if (registroExistente.StockFinalC32.HasValue && registroExistente.StockFinalF40.HasValue)
                            {
                                <div class="alert alert-primary">
                                    <h5 class="mb-2">
                                        <i class="fas fa-industry me-2"></i>Producciˇn Total del Turno
                                    </h5>
                                    <h2 class="mb-0">
                                        <span class="badge bg-primary fs-3">
                                            @registroExistente.ProduccionTotalNeta palets
                                        </span>
                                    </h2>
                                </div>
                            }

                            <hr />

                            <div class="row">
                                <div class="col-6">
                                    <p class="mb-1"><strong>Registrado por:</strong></p>
                                    <p class="text-muted">@registroExistente.PersonalNombre</p>
                                </div>
                                <div class="col-6">
                                    <p class="mb-1"><strong>Fecha Inicial:</strong></p>
                                    <p class="text-muted">@registroExistente.FechaHoraRegistroInicial.ToString("dd/MM/yyyy HH:mm")</p>
                                </div>
                            </div>

                            @if (registroExistente.FechaHoraRegistroFinal.HasValue)
                            {
                                <div class="row">
                                    <div class="col-12">
                                        <p class="mb-1"><strong>Fecha Final:</strong></p>
                                        <p class="text-muted">@registroExistente.FechaHoraRegistroFinal.Value.ToString("dd/MM/yyyy HH:mm")</p>
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(registroExistente.ObservacionesInicio))
                            {
                                <div class="alert alert-info">
                                    <strong>Observaciones Inicio:</strong>
                                    <p class="mb-0">@registroExistente.ObservacionesInicio</p>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(registroExistente.ObservacionesFin))
                            {
                                <div class="alert alert-warning">
                                    <strong>Observaciones Fin:</strong>
                                    <p class="mb-0">@registroExistente.ObservacionesFin</p>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="card shadow">
                        <div class="card-header bg-info text-white">
                            <h5 class="mb-0">
                                <i class="fas fa-info-circle me-2"></i>Informaciˇn
                            </h5>
                        </div>
                        <div class="card-body">
                            <p><i class="fas fa-check-circle text-success me-2"></i>Registra primero el stock inicial</p>
                            <p><i class="fas fa-clock text-warning me-2"></i>Al finalizar el turno, registra el stock final</p>
                            <p class="mb-0"><i class="fas fa-calculator text-info me-2"></i>El sistema calcularß automßticamente la producciˇn neta</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private bool cargando = true;
    private bool guardando = false;
    private TurnoDto? turnoActual;
    private RegistroStockPaletsDto? registroExistente;
    
    private CreateStockInicialDto stockInicialDto = new();
    private UpdateStockFinalDto stockFinalDto = new();
    
    private string mensajeError = "";
    private string mensajeExito = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        cargando = true;
        StateHasChanged();

        try
        {
            var turnos = await TurnoService.GetTurnosAsync();
            turnoActual = turnos.FirstOrDefault(t => t.Estado == "En Proceso");

            if (turnoActual != null)
            {
                await CargarRegistroExistente();
                
                // Inicializar DTOs
                stockInicialDto.TurnoProduccionID = turnoActual.TurnoProduccionID;
                stockInicialDto.PersonalID = 1; // TODO: Obtener del usuario autenticado
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al cargar datos");
            mensajeError = $"Error: {ex.Message}";
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private async Task CargarRegistroExistente()
    {
        try
        {
            var response = await Http.GetAsync($"api/stockpalets/turno/{turnoActual!.TurnoProduccionID}");
            
            if (response.IsSuccessStatusCode)
            {
                var apiResponse = await response.Content.ReadFromJsonAsync<ApiResponse<RegistroStockPaletsDto>>();
                registroExistente = apiResponse?.Data;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al cargar registro existente");
        }
    }

    private async Task RegistrarStockInicial()
    {
        guardando = true;
        mensajeError = "";
        mensajeExito = "";
        StateHasChanged();

        try
        {
            var response = await Http.PostAsJsonAsync("api/stockpalets/inicial", stockInicialDto);
            
            if (response.IsSuccessStatusCode)
            {
                mensajeExito = "Stock inicial registrado exitosamente";
                await CargarRegistroExistente();
                stockInicialDto = new CreateStockInicialDto 
                { 
                    TurnoProduccionID = turnoActual!.TurnoProduccionID,
                    PersonalID = stockInicialDto.PersonalID
                };
            }
            else
            {
                var errorResponse = await response.Content.ReadFromJsonAsync<ApiResponse<object>>();
                mensajeError = errorResponse?.Message ?? "Error al registrar stock inicial";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al registrar stock inicial");
            mensajeError = $"Error: {ex.Message}";
        }
        finally
        {
            guardando = false;
            StateHasChanged();
        }
    }

    private async Task RegistrarStockFinal()
    {
        guardando = true;
        mensajeError = "";
        mensajeExito = "";
        StateHasChanged();

        try
        {
            var response = await Http.PutAsJsonAsync($"api/stockpalets/{registroExistente!.RegistroStockPaletsID}/final", stockFinalDto);
            
            if (response.IsSuccessStatusCode)
            {
                mensajeExito = "Stock final registrado exitosamente";
                await CargarRegistroExistente();
                stockFinalDto = new UpdateStockFinalDto();
            }
            else
            {
                var errorResponse = await response.Content.ReadFromJsonAsync<ApiResponse<object>>();
                mensajeError = errorResponse?.Message ?? "Error al registrar stock final";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al registrar stock final");
            mensajeError = $"Error: {ex.Message}";
        }
        finally
        {
            guardando = false;
            StateHasChanged();
        }
    }

    public class ApiResponse<T>
    {
        public bool Success { get; set; }
        public T? Data { get; set; }
        public string? Message { get; set; }
    }
}