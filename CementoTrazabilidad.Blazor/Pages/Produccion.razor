    private string FormatearTiempo(TimeSpan? tiempo)
    {
        if (!tiempo.HasValue) return "--";

        if (tiempo.Value.TotalHours >= 1)
        {
            return $"{tiempo.Value.Hours}h {tiempo.Value.Minutes}m {tiempo.Value.Seconds}s";
        }
        else if (tiempo.Value.TotalMinutes >= 1)
        {
            return $"{tiempo.Value.Minutes}m {tiempo.Value.Seconds}s";
        }
        else
        {
            return $"{tiempo.Value.Seconds}s";
        }
    }

