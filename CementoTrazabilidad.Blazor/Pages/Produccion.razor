@page "/produccion"
@layout MainLayout
@attribute [Authorize(Roles = "Administrador,Supervisor,JefeTurno,Operario")]
@using CementoTrazabilidad.Shared.DTOs
@using CementoTrazabilidad.Blazor.Components.Shared
@using Microsoft.AspNetCore.Components.Forms
@using System.Net.Http.Json
@using System.Text.Json
@inject ITurnoService TurnoService
@inject IPersonalService PersonalService
@inject NavigationManager Navigation
@inject ILogger<Produccion> Logger
@inject HttpClient Http

<PageTitle>Producción - CementoTrazabilidad</PageTitle>

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col">
            <h1><i class="fas fa-industry me-2"></i>Turnos de Producción</h1>
            <p class="text-muted">Gestión y seguimiento de turnos activos</p>
        </div>
        <div class="col-auto">
            <button class="btn btn-primary" @onclick="MostrarModalNuevoTurno">
                <i class="fas fa-plus me-2"></i>Nuevo Turno
            </button>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Fecha</label>
                    <input type="date" class="form-control"
                           @bind="filtroFecha" 
                           @bind:after="AplicarFiltros" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Estado</label>
                    <select class="form-select" 
                            @bind="filtroEstado"
                            @bind:after="AplicarFiltros">
                        <option value="">Todos</option>
                        <option value="Programado">Programado</option>
                        <option value="En Proceso">En Proceso</option>
                        <option value="Finalizado">Finalizado</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Número de Turno</label>
                    <select class="form-select" 
                            @bind="filtroTurnoNumero"
                            @bind:after="AplicarFiltros">
                        <option value="0">Todos</option>
                        <option value="1">Turno 1</option>
                        <option value="2">Turno 2</option>
                        <option value="3">Turno 3</option>
                        <option value="4">Turno 4</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-outline-secondary w-100" @onclick="LimpiarFiltros">
                        <i class="fas fa-eraser me-2"></i>Limpiar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Estado de carga -->
    @if (cargando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="mt-2">Cargando turnos...</p>
        </div>
    }
    else if (turnosFiltrados.Count == 0)
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>
            @(turnos.Count == 0 ? "No hay turnos registrados." : "No se encontraron turnos con los filtros aplicados.")
        </div>
    }
    else
    {
        <!-- Tabla de turnos -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-list me-2"></i>
                    Turnos (@turnosFiltrados.Count)
                </h5>
                <div class="text-muted small">
                    @if (turnosAbiertos > 0)
                    {
                        <span class="badge bg-success me-2">@turnosAbiertos abiertos</span>
                    }
                    Mostrando @turnosFiltrados.Count turnos
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Fecha</th>
                                <th>Turno</th>
                                <th>Estado</th>
                                <th>Inicio</th>
                                <th>Fin</th>
                                <th>Personal</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var turno in turnosFiltrados)
                            {
                                var cantidadPersonal = GetCantidadPersonal(turno.TurnoProduccionID);
                                <tr>
                                    <td>
                                        <strong>#@turno.TurnoProduccionID</strong>
                                    </td>
                                    <td>@turno.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <span class="badge bg-secondary">
                                            Turno @turno.TurnoNumero
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @GetEstadoBadge(turno.Estado)">
                                            @turno.Estado
                                        </span>
                                    </td>
                                    <td>
                                        <span class="text-dark">@ObtenerHoraInicio(turno.TurnoNumero)</span>
                                    </td>
                                    <td>
                                        <span class="text-dark">@ObtenerHoraFin(turno.TurnoNumero)</span>
                                    </td>
                                    <td>
                                        @if (cantidadPersonal > 0)
                                        {
                                            <span class="badge bg-info"
                                                  @onclick="() => AbrirModalAsignarPersonal(turno.TurnoProduccionID)"
                                                  style="cursor: pointer;"
                                                  title="@cantidadPersonal persona(s) asignada(s). Haz clic para gestionar.">
                                                <i class="fas fa-users me-1"></i>
                                                @cantidadPersonal
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning"
                                                  @onclick="() => AbrirModalAsignarPersonal(turno.TurnoProduccionID)"
                                                  style="cursor: pointer;"
                                                  title="Haz clic para asignar personal">
                                                <i class="fas fa-user-plus me-1"></i>
                                                Sin personal
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary"
                                                    @onclick="() => VerDetalle(turno.TurnoProduccionID)"
                                                    title="Ver detalle">
                                                <i class="fas fa-eye"></i>
                                            </button>

                                            <!-- Botón para asignar personal -->
                                            @if (turno.Estado == "Produccion" || turno.Estado == "Programado" || turno.Estado == "En Proceso")
                                            {
                                                <button class="btn btn-outline-info"
                                                        title="Asignar personal"
                                                        @onclick="() => AbrirModalAsignarPersonal(turno.TurnoProduccionID)">
                                                    <i class="fas fa-user-plus"></i>
                                                </button>
                                            }

                                            @if (turno.Estado == "Programado")
                                            {
                                                <button class="btn btn-outline-success"
                                                        title="Iniciar turno"
                                                        @onclick="async () => await IniciarTurno(turno.TurnoProduccionID)">
                                                    <i class="fas fa-play"></i>
                                                </button>
                                            }

                                            @if (turno.Estado == "En Proceso")
                                            {
                                                /*<button class="btn btn-outline-warning"
                                                        @onclick="() => RegistrarParada(turno.TurnoProduccionID)"
                                                        title="Registrar parada">
                                                    <i class="fas fa-pause"></i>
                                               </button>*/
                                                <button class="btn btn-outline-danger"
                                                        title="Finalizar turno"
                                                        @onclick="async () => await FinalizarTurno(turno.TurnoProduccionID)">
                                                    <i class="fas fa-stop"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal para nuevo turno -->
@if (mostrarModalNuevoTurno)
{
    <div class="modal show d-block" tabindex="-1" role="dialog" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-plus me-2"></i>
                        Nuevo Turno de Producción
                    </h5>
                    <button type="button" class="btn-close" @onclick="CerrarModal"
                            disabled="@creandoTurno"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@nuevoTurnoDto" OnValidSubmit="@CrearTurno">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label">Fecha *</label>
                            <InputDate class="form-control" @bind-Value="nuevoTurnoDto.Fecha" />
                            <ValidationMessage For="@(() => nuevoTurnoDto.Fecha)" />
                            <div class="form-text">Fecha del turno</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Número de Turno *</label>
                            <select class="form-select" @bind="nuevoTurnoDto.TurnoNumero">
                                <option value="1">Turno 1 (06:00 - 14:30)</option>
                                <option value="2">Turno 2 (14:30 - 22:30)</option>
                                <option value="3">Turno 3 (22:30 - 06:00)</option>
                            </select>
                            <ValidationMessage For="@(() => nuevoTurnoDto.TurnoNumero)" />
                        </div>

                        @if (!string.IsNullOrEmpty(mensajeError))
                        {
                            <div class="alert alert-danger">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                @mensajeError
                            </div>
                        }

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary" disabled="@creandoTurno">
                                @if (creandoTurno)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                    <span>Creando...</span>
                                }
                                else
                                {
                                    <i class="fas fa-plus me-2"></i>
                                    <span>Crear Turno</span>
                                }
                            </button>
                            <button type="button" class="btn btn-secondary ms-2"
                                    @onclick="CerrarModal" disabled="@creandoTurno">
                                Cancelar
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal para asignar personal -->
@if (mostrarModalAsignarPersonal)
{
    <div class="modal show d-block" tabindex="-1" role="dialog" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-user-plus me-2"></i>
                        Asignar Personal al Turno @turnoSeleccionadoId
                    </h5>
                    <button type="button" class="btn-close" @onclick="CerrarModalAsignar"></button>
                </div>

                <div class="modal-body">
                    <!-- Mensaje de error -->
                    @if (!string.IsNullOrEmpty(mensajeErrorAsignacion))
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            @mensajeErrorAsignacion
                        </div>
                    }

                    <!-- Estado de carga -->
                    @if (cargandoPersonalDisponible)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                            <p class="mt-2">Cargando personal disponible...</p>
                        </div>
                    }
                    else if (personalDisponible.Count == 0)
                    {
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            No hay personal disponible para asignar a este turno.
                        </div>
                    }
                    else
                    {
                        <!-- Tabla de personal disponible -->
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th width="50px"></th>
                                        <th>Legajo</th>
                                        <th>Nombre</th>
                                        <th>Rol Principal</th>
                                        <th>Asignar como</th>
                                        <th>Acción</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var persona in personalDisponible)
                                    {
                                        var rolTurno = rolesTurnoSeleccionados.ContainsKey(persona.PersonalID)
                                        ? rolesTurnoSeleccionados[persona.PersonalID]
                                        : persona.Rol;

                                        <tr>
                                            <td>
                                                <input type="checkbox"
                                                       @bind="personalSeleccionadoIds[persona.PersonalID]"
                                                       disabled="@asignandoPersonal" />
                                            </td>
                                            <td>
                                                <strong>@persona.Legajo</strong>
                                            </td>
                                            <td>@persona.Nombre</td>
                                            <td>
                                                <span class="badge @GetRolBadge(persona.Rol)">
                                                    @persona.Rol
                                                </span>
                                            </td>
                                            <td>
                                                <select class="form-select form-select-sm"
                                                        @bind="rolesTurnoSeleccionados[persona.PersonalID]"
                                                        disabled="@asignandoPersonal">
                                                    <option value="Operario">Operario</option>
                                                    <option value="Supervisor">Supervisor</option>
                                                    <option value="Jefe de Turno">Jefe de Turno</option>
                                                    <option value="Ayudante">Ayudante</option>
                                                    <option value="Mantenimiento">Mantenimiento</option>
                                                </select>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-primary"
                                                        @onclick="async () => await AsignarPersonaIndividual(persona)"
                                                        disabled="@asignandoPersonal">
                                                    <i class="fas fa-user-plus"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Contador y botones -->
                        <div class="mt-4 d-flex justify-content-between align-items-center">
                            <div>
                                <span class="text-muted">
                                    <i class="fas fa-users me-1"></i>
                                    Disponibles: @personalDisponible.Count |
                                    Seleccionados: @personalSeleccionadoIds.Count(kv => kv.Value)
                                </span>
                            </div>

                            <div class="btn-group">
                                <button class="btn btn-primary"
                                        @onclick="async () => await AsignarPersonalMultiple()"
                                        disabled="@(asignandoPersonal || !personalSeleccionadoIds.Any(kv => kv.Value))">
                                    @if (asignandoPersonal)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                        <span>Asignando...</span>
                                    }
                                    else
                                    {
                                        <i class="fas fa-user-plus me-2"></i>
                                        <span>Asignar Seleccionados</span>
                                    }
                                </button>

                                <button class="btn btn-outline-secondary"
                                        @onclick="CerrarModalAsignar"
                                        disabled="@asignandoPersonal">
                                    Cancelar
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Resumen de carga por zonas - CON CONTROLES ACTIVOS -->
<div class="card mb-3">
    <div class="card-header bg-info text-white">
        <h6 class="mb-0"><i class="fas fa-truck-loading me-2"></i>Control de Carga</h6>
    </div>
    <div class="card-body">
        @if (turnoActual == null)
        {
            <div class="alert alert-warning">
                <i class="fas fa-info-circle me-2"></i>
                No hay turno activo. El control de carga está deshabilitado.
            </div>
        }
        else
        {
            <!-- Mensajes de error -->
            @if (!string.IsNullOrEmpty(mensajeErrorCarga))
            {
                <div class="alert alert-danger mb-3">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    @mensajeErrorCarga
                </div>
            }

            @if (resumenCarga != null && resumenCarga.Any())
            {
                <div class="row">
                    @foreach (var zona in resumenCarga)
                    {
                        var puedeIniciar = PuedeIniciarCarga(zona.ZonaCarga, zona.Estado);
                        var mensajeBloqueo = ObtenerMensajeBloqueo(zona.ZonaCarga, zona.Estado);
                        var cardClass = GetCardClass(zona.Estado);

                        <div class="col-md-6 mb-3">
                            <div class="card @cardClass">
                                <div class="card-body">
                                    <h6 class="card-title">
                                        <i class="fas @(zona.ZonaCarga == "Anden" ? "fa-truck-loading" : "fa-pallet") me-2"></i>
                                        @zona.ZonaCarga
                                    </h6>

                                    <p class="mb-1">
                                        <strong>Estado:</strong>
                                        <span class="badge @GetBadgeClass(zona.Estado)">@zona.Estado</span>
                                    </p>

                                    @if (zona.HoraInicio.HasValue)
                                    {
                                        <p class="mb-1">
                                            <i class="fas fa-play text-success me-2"></i>
                                            Inicio: @zona.HoraInicio.Value.ToString("HH:mm:ss")
                                        </p>
                                    }

                                    @if (zona.HoraFin.HasValue)
                                    {
                                        <p class="mb-1">
                                            <i class="fas fa-stop text-danger me-2"></i>
                                            Fin: @zona.HoraFin.Value.ToString("HH:mm:ss")
                                        </p>
                                        <p class="mb-0">
                                            <i class="fas fa-clock me-2"></i>
                                            Duración: @FormatearTiempo(zona.TiempoTotal)
                                        </p>
                                    }

                                    <!-- Mensaje de bloqueo -->
                                    @if (!string.IsNullOrEmpty(mensajeBloqueo) && !puedeIniciar)
                                    {
                                        <div class="alert alert-warning alert-sm mt-2 mb-2 py-1 px-2">
                                            <small><i class="fas fa-lock me-1"></i>@mensajeBloqueo</small>
                                        </div>
                                    }

                                    <!-- Botones de control -->
                                    <div class="btn-group w-100 mt-3">
                                        @if (zona.Estado == "No iniciado" || zona.Estado == "Finalizado")
                                        {
                                            <button class="btn btn-success btn-sm"
                                                    @onclick="() => IniciarCarga(zona.ZonaCarga)"
                                                    disabled="@(!puedeIniciar)"
                                                    title="@(puedeIniciar ? $"Iniciar carga en {zona}" : mensajeBloqueo)">
                                                @if (puedeIniciar)
                                                {
                                                    <i class="fas fa-play me-1"></i>
                                                    <span>Iniciar</span>
                                                }
                                                else
                                                {
                                                    <i class="fas fa-lock me-1"></i>
                                                    <span>Bloqueado</span>
                                                }
                                            </button>
                                        }

                                        @if (zona.Estado == "En curso")
                                        {
                                            <button class="btn btn-danger btn-sm"
                                                    @onclick="() => FinalizarCarga(zona.ZonaCarga)"
                                                    title="Finalizar carga">
                                                <i class="fas fa-stop me-1"></i>Finalizar
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-4 text-muted">
                    <i class="fas fa-info-circle fa-2x mb-2"></i>
                    <p>No hay datos de carga disponibles</p>
                </div>
            }
        }
    </div>
</div>

@code {
    // Listas y estados
    private List<TurnoDto> turnos = new();
    private List<TurnoDto> turnosFiltrados = new();
    private Dictionary<int, int> cantidadPersonalPorTurno = new();
    private int turnosAbiertos = 0;
    private bool cargando = true;

    // Turno actual
    private TurnoDto? turnoActual;

    // Filtros
    private DateOnly? filtroFecha = DateOnly.FromDateTime(DateTime.Today);
    private string filtroEstado = "";
    private int filtroTurnoNumero = 0;

    // Modal nuevo turno
    private bool mostrarModalNuevoTurno = false;
    private bool creandoTurno = false;
    private CreateTurnoDto nuevoTurnoDto = new();
    private string mensajeError = "";

    // Modal asignar personal
    private bool mostrarModalAsignarPersonal = false;
    private int turnoSeleccionadoId = 0;
    private List<PersonalDto> personalDisponible = new();
    private Dictionary<int, bool> personalSeleccionadoIds = new();
    private Dictionary<int, string> rolesTurnoSeleccionados = new();
    private bool cargandoPersonalDisponible = false;
    private bool asignandoPersonal = false;
    private string mensajeErrorAsignacion = "";

    // Resumen de carga
    private List<ResumenCargaDto>? resumenCarga;

    // Variable para mensajes de error en control de carga
    private string mensajeErrorCarga = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        cargando = true;
        StateHasChanged();

        try
        {
            // Cargar todos los turnos
            turnos = await TurnoService.GetTurnosAsync();

            // Contar turnos abiertos
            turnosAbiertos = turnos.Count(t => t.Estado == "Produccion" || t.Estado == "En Proceso");

            // Obtener el turno actual (el primer turno "En Proceso")
            turnoActual = turnos.FirstOrDefault(t => t.Estado == "En Proceso");

            // Cargar resumen de carga si hay un turno activo
            if (turnoActual != null)
            {
                await CargarResumenCarga();
            }

            // Cargar cantidades de personal
            await CargarCantidadPersonalPorTurno();

            AplicarFiltros();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al cargar datos de producción");
            mensajeError = $"Error al cargar turnos: {ex.Message}";
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private async Task CargarCantidadPersonalPorTurno()
    {
        cantidadPersonalPorTurno.Clear();
        foreach (var turno in turnos)
        {
            try
            {
                var personal = await TurnoService.GetPersonalTurnoAsync(turno.TurnoProduccionID);
                cantidadPersonalPorTurno[turno.TurnoProduccionID] = personal?.Count ?? 0;
            }
            catch
            {
                cantidadPersonalPorTurno[turno.TurnoProduccionID] = 0;
            }
        }
    }

    private int GetCantidadPersonal(int turnoId)
    {
        return cantidadPersonalPorTurno.TryGetValue(turnoId, out var cantidad) ? cantidad : 0;
    }

    private void AplicarFiltros()
    {
        turnosFiltrados = turnos.ToList();

        // Filtrar por fecha
        if (filtroFecha.HasValue)
        {
            turnosFiltrados = turnosFiltrados
                .Where(t => t.Fecha == filtroFecha.Value)
                .ToList();
        }

        // Filtrar por estado
        if (!string.IsNullOrEmpty(filtroEstado))
        {
            turnosFiltrados = turnosFiltrados
                .Where(t => t.Estado == filtroEstado)
                .ToList();
        }

        // Filtrar por número de turno
        if (filtroTurnoNumero > 0)
        {
            turnosFiltrados = turnosFiltrados
                .Where(t => t.TurnoNumero == filtroTurnoNumero)
                .ToList();
        }

        // Ordenar
        turnosFiltrados = turnosFiltrados
            .OrderByDescending(t => t.Fecha)
            .ThenBy(t => t.TurnoNumero)
            .ToList();
    }

    private void LimpiarFiltros()
    {
        filtroFecha = DateOnly.FromDateTime(DateTime.Today);
        filtroEstado = "";
        filtroTurnoNumero = 0;
        AplicarFiltros();
    }

    private string GetEstadoBadge(string estado)
    {
        return estado switch
        {
            "Produccion" => "bg-secondary",
            "Programado" => "bg-secondary",
            "En Proceso" => "bg-success",
            "Finalizado" => "bg-primary",
            "Pausado" => "bg-warning",
            _ => "bg-info"
        };
    }

