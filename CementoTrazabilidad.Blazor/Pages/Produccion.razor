    private async Task CargarResumenCarga()
    {
        if (turnoActual == null)
        {
            resumenCarga = null;
            return;
        }

        try
        {
            Console.WriteLine($"🔄 Llamando a API: api/eventocarga/turno/{turnoActual.TurnoProduccionID}/resumen");

            // PRIMERO: Hacer la solicitud sin deserializar
            var response = await Http.GetAsync($"api/eventocarga/turno/{turnoActual.TurnoProduccionID}/resumen");

            Console.WriteLine($"📥 Status Code: {response.StatusCode}");

            if (response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"📦 Contenido de respuesta: {content}");

                // Intentar deserializar
                try
                {
                    var apiResponse = System.Text.Json.JsonSerializer.Deserialize<ApiResponse<List<ResumenCargaDto>>>(
                        content,
                        new System.Text.Json.JsonSerializerOptions
                        {
                            PropertyNameCaseInsensitive = true
                        });

                    if (apiResponse?.Success == true && apiResponse.Data != null)
                    {
                        resumenCarga = apiResponse.Data;
                        Console.WriteLine($"✅ Resumen cargado: {resumenCarga.Count} zonas");
                    }
                    else
                    {
                        Console.WriteLine($"⚠️ API Success=false: {apiResponse?.Message}");
                        resumenCarga = new List<ResumenCargaDto>();
                    }
                }
                catch (JsonException jsonEx)
                {
                    Console.WriteLine($"❌ Error de deserialización JSON: {jsonEx.Message}");
                    Console.WriteLine($"Contenido raw: {content}");
                    resumenCarga = new List<ResumenCargaDto>();
                }
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"❌ Error HTTP {response.StatusCode}: {errorContent}");
                resumenCarga = new List<ResumenCargaDto>();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al cargar resumen de carga");
            Console.WriteLine($"💥 Excepción completa: {ex.ToString()}");
            resumenCarga = new List<ResumenCargaDto>();
        }
    }
    // ==================== MÉTODOS PARA CONTROL DE CARGA ====================
    private async Task IniciarCarga(string zona)
    {
        if (turnoActual == null)
        {
            mensajeErrorCarga = "No hay turno activo para iniciar carga";
            StateHasChanged();
            return;
        }

        Console.WriteLine($"🔄 Intentando iniciar carga en {zona} para turno {turnoActual.TurnoProduccionID}");

        // Obtener el estado actual de la zona
        var zonaResumen = resumenCarga?.FirstOrDefault(z => z.ZonaCarga == zona);
        if (zonaResumen == null)
        {
            mensajeErrorCarga = $"No se encontró información para la zona {zona}";
            StateHasChanged();
            return;
        }

        Console.WriteLine($"📊 Estado actual de {zona}: {zonaResumen.Estado}");

        // Verificar si ya se puede iniciar
        if (!PuedeIniciarCarga(zona, zonaResumen.Estado))
        {
            mensajeErrorCarga = ObtenerMensajeBloqueo(zona, zonaResumen.Estado);
            Console.WriteLine($"❌ No se puede iniciar: {mensajeErrorCarga}");
            StateHasChanged();
            return;
        }

        try
        {
            var dto = new RegistrarEventoCargaDto
            {
                TurnoProduccionID = turnoActual.TurnoProduccionID,
                ZonaCarga = zona,
                TipoEvento = "Inicio",
                Observaciones = $"Inicio de carga en {zona}"
            };

            Console.WriteLine($"📤 Enviando solicitud para iniciar carga en {zona}");
            var response = await Http.PostAsJsonAsync("api/eventocarga", dto);

            if (response.IsSuccessStatusCode)
            {
                Console.WriteLine($"✅ Carga iniciada exitosamente en {zona}");
                mensajeErrorCarga = "";

                // Esperar un momento antes de recargar
                await Task.Delay(500);
                await CargarResumenCarga();
                StateHasChanged();
            }
            else
            {
                // Intentar obtener el mensaje de error del servidor
                try
                {
                    var errorResponse = await response.Content.ReadFromJsonAsync<ApiResponse<object>>();
                    mensajeErrorCarga = errorResponse?.Message ?? "Error al iniciar la carga";
                    Console.WriteLine($"❌ Error del servidor: {mensajeErrorCarga}");
                }
                catch
                {
                    var errorText = await response.Content.ReadAsStringAsync();
                    mensajeErrorCarga = $"Error del servidor: {errorText}";
                    Console.WriteLine($"❌ Error del servidor (raw): {errorText}");
                }

                // Recargar para obtener estado actualizado
                await CargarResumenCarga();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, $"Error al iniciar carga en {zona}");
            mensajeErrorCarga = $"Error al iniciar carga: {ex.Message}";
            Console.WriteLine($"❌ Excepción: {ex.Message}");

            // Recargar para obtener estado actual
            await CargarResumenCarga();
            StateHasChanged();
        }
    }

