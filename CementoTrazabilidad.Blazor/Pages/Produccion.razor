    }

    private bool PuedeIniciarCarga(string zona, string estado)
    {
        Console.WriteLine($"🔍 Validando si se puede iniciar {zona} (Estado: {estado})");

        // REGLA 1: Si esta zona ya está en curso, no se puede iniciar de nuevo
        if (estado == "En curso")
        {
            Console.WriteLine($"   ❌ {zona} ya está en curso");
            return false;
        }

        // REGLA 2: Verificar si hay otra zona en curso (máquina única)
        if (resumenCarga != null)
        {
            var otraZonaEnCurso = resumenCarga
                .Where(z => z.ZonaCarga != zona)
                .FirstOrDefault(z => z.Estado == "En curso");

            if (otraZonaEnCurso != null)
            {
                Console.WriteLine($"   ❌ {zona} bloqueada porque {otraZonaEnCurso.ZonaCarga} está en curso");
                // No se puede iniciar esta zona si hay otra en curso
                return false;
            }
        }

        // REGLA 3: Flujo específico de producción - MODIFICADA
        if (zona == "Paletizado" && resumenCarga != null)
        {
            var anden = resumenCarga.FirstOrDefault(z => z.ZonaCarga == "Anden");

            // **NUEVA LÓGICA: Paletizado puede iniciar independientemente de Andén**
            // Solo aplicamos la regla de máquina única (regla 2)
            // Comentamos las restricciones específicas de flujo
            /*
            if (anden != null)
            {
                // Si Andén está en curso, no se puede iniciar Paletizado (regla de máquina única)
                if (anden.Estado == "En curso")
                {
                    Console.WriteLine($"   ❌ Paletizado bloqueado porque Andén está en curso");
                    return false;
                }

                // Si Andén no está iniciado, podemos iniciar Paletizado directamente
                // No bloqueamos Paletizado si Andén está "No iniciado" o "Finalizado"
            }
            */
        }

        // Permitir iniciar solo si está "No iniciado" o "Finalizado"
        if (estado == "No iniciado" || estado == "Finalizado")
        {
            Console.WriteLine($"   ✅ {zona} puede iniciar (Estado: {estado})");
            return true;
        }

        Console.WriteLine($"   ❌ {zona} no puede iniciar (Estado: {estado})");
        return false;
    }

    private string ObtenerMensajeBloqueo(string zona, string estado)
    {
        // MENSAJE 1: Ya en curso
        if (estado == "En curso")
        {
            return $"La carga en {zona} ya está en curso. Finalízala antes de reiniciar.";
        }

        // MENSAJE 2: Otra zona en curso
        if (resumenCarga != null)
        {
            var otraZonaEnCurso = resumenCarga
                .FirstOrDefault(z => z.ZonaCarga != zona && z.Estado == "En curso");

            if (otraZonaEnCurso != null)
            {
                return $"La máquina está ocupada en '{otraZonaEnCurso.ZonaCarga}'. Finalízala primero.";
            }
        }

        // MENSAJE 3: Flujo Andén → Paletizado (OPCIONAL - comentado)
        /*
        if (zona == "Paletizado")
        {
            var anden = resumenCarga?.FirstOrDefault(z => z.ZonaCarga == "Anden");

            if (anden != null)
            {
                if (anden.Estado == "No iniciado")
                {
                    return "Debes iniciar y completar 'Andén' primero.";
                }
            }
        }
        */

        return "No se puede iniciar la carga en este momento.";
    }

