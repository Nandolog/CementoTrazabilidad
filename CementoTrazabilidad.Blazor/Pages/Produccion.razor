    private async Task CrearTurno()
    {
        creandoTurno = true;
        mensajeError = "";
        StateHasChanged();

        try
        {
            // Validar que no exista ya un turno para esta fecha y número
            var existeTurno = turnos.Any(t =>
                t.Fecha == nuevoTurnoDto.Fecha &&
                t.TurnoNumero == nuevoTurnoDto.TurnoNumero);

            if (existeTurno)
            {
                mensajeError = $"Ya existe un Turno {nuevoTurnoDto.TurnoNumero} para la fecha {nuevoTurnoDto.Fecha:dd/MM/yyyy}";
                creandoTurno = false;
                StateHasChanged();
                return;
            }

            // Crear el turno
            var success = await TurnoService.CreateTurnoAsync(nuevoTurnoDto);

            if (success)
            {
                mostrarModalNuevoTurno = false;
                await CargarDatos();

                // Mostrar mensaje de éxito
                Console.WriteLine($"Turno creado exitosamente para {nuevoTurnoDto.Fecha:dd/MM/yyyy}");
            }
            else
            {
                mensajeError = "Error al crear el turno. Verifique los datos e intente nuevamente.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al crear turno");
            mensajeError = $"Error: {ex.Message}";
        }
        finally
        {
            creandoTurno = false;
            StateHasChanged();
        }
    }

    // ==================== ASIGNACIÓN DE PERSONAL ====================
    private async Task AbrirModalAsignarPersonal(int turnoId)
    {
        try
        {
            turnoSeleccionadoId = turnoId;
            mensajeErrorAsignacion = "";
            personalSeleccionadoIds.Clear();
            rolesTurnoSeleccionados.Clear();
            cargandoPersonalDisponible = true;

            mostrarModalAsignarPersonal = true;
            StateHasChanged();

            // 1. Obtener todo el personal activo
            var todoElPersonal = await PersonalService.GetPersonalAsync();

            if (todoElPersonal == null)
            {
                mensajeErrorAsignacion = "Error: No se pudo obtener el personal";
                cargandoPersonalDisponible = false;
                StateHasChanged();
                return;
            }

            if (!todoElPersonal.Any())
            {
                mensajeErrorAsignacion = "No hay personal registrado en el sistema";
                cargandoPersonalDisponible = false;
                StateHasChanged();
                return;
            }

            var personalActivo = todoElPersonal.Where(p => p.Activo).ToList();

            if (!personalActivo.Any())
            {
                mensajeErrorAsignacion = "No hay personal activo disponible";
                cargandoPersonalDisponible = false;
                StateHasChanged();
                return;
            }

            // 2. Obtener personal ya asignado a este turno
            var personalAsignado = await TurnoService.GetPersonalTurnoAsync(turnoId);
            var idsAsignados = personalAsignado?.Select(p => p.PersonalID).ToList() ?? new List<int>();

            // 3. Filtrar personal disponible (activo y no asignado)
            personalDisponible = personalActivo
                .Where(p => !idsAsignados.Contains(p.PersonalID))
                .OrderBy(p => p.Nombre)
                .ToList();

            if (personalDisponible.Any())
            {
                foreach (var p in personalDisponible)
                {
                    // Inicializar checkbox y rol
                    personalSeleccionadoIds[p.PersonalID] = false;
                    rolesTurnoSeleccionados[p.PersonalID] = p.Rol;
                }
            }
            else
            {
                mensajeErrorAsignacion = "Todo el personal disponible ya está asignado a este turno";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, $"Error al cargar personal disponible para turno {turnoId}");
            mensajeErrorAsignacion = $"Error al cargar personal: {ex.Message}";
        }
        finally
        {
            cargandoPersonalDisponible = false;
            StateHasChanged();
        }
    }

    private void CerrarModalAsignar()
    {
        if (!asignandoPersonal)
        {
            mostrarModalAsignarPersonal = false;
            personalDisponible.Clear();
            personalSeleccionadoIds.Clear();
            rolesTurnoSeleccionados.Clear();
            mensajeErrorAsignacion = "";
        }
    }

    private async Task AsignarPersonaIndividual(PersonalDto persona)
    {
        try
        {
            asignandoPersonal = true;
            mensajeErrorAsignacion = "";
            StateHasChanged();

            // Crear DTO de asignación
            var rolTurno = rolesTurnoSeleccionados.ContainsKey(persona.PersonalID)
                ? rolesTurnoSeleccionados[persona.PersonalID]
                : persona.Rol;

            var asignacionDto = new AsignarPersonalDto
            {
                PersonalId = persona.PersonalID,
                RolTurno = rolTurno
            };

            // Llamar al servicio
            var success = await TurnoService.AsignarPersonalAsync(turnoSeleccionadoId, asignacionDto);

            if (success)
            {
                // Remover de la lista de disponibles
                personalDisponible = personalDisponible
                    .Where(p => p.PersonalID != persona.PersonalID)
                    .ToList();

                // Actualizar la cantidad en la tabla principal
                await CargarCantidadPersonalPorTurno();
                await CargarDatos();

                // Mostrar mensaje de éxito
                mensajeErrorAsignacion = $"✅ {persona.Nombre} asignado como {rolTurno}";
            }
            else
            {
                mensajeErrorAsignacion = "❌ Error al asignar personal";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, $"Error al asignar personal {persona.PersonalID} al turno {turnoSeleccionadoId}");
            mensajeErrorAsignacion = $"Error: {ex.Message}";
        }
        finally
        {
            asignandoPersonal = false;
            StateHasChanged();
        }
    }

    private async Task AsignarPersonalMultiple()
    {
        try
        {
            asignandoPersonal = true;
            mensajeErrorAsignacion = "";
            StateHasChanged();

            var seleccionadosIds = personalSeleccionadoIds
                .Where(kv => kv.Value)
                .Select(kv => kv.Key)
                .ToList();

            if (seleccionadosIds.Count == 0)
            {
                mensajeErrorAsignacion = "❌ No hay personal seleccionado";
                return;
            }

            int asignadosExitosos = 0;
            List<string> errores = new();

            foreach (var personalId in seleccionadosIds)
            {
                try
                {
                    var persona = personalDisponible.FirstOrDefault(p => p.PersonalID == personalId);
                    if (persona == null) continue;

                    var rolTurno = rolesTurnoSeleccionados.ContainsKey(personalId)
                        ? rolesTurnoSeleccionados[personalId]
                        : persona.Rol;

                    var asignacionDto = new AsignarPersonalDto
                    {
                        PersonalId = persona.PersonalID,
                        RolTurno = rolTurno
                    };

                    var success = await TurnoService.AsignarPersonalAsync(turnoSeleccionadoId, asignacionDto);

                    if (success)
                    {
                        asignadosExitosos++;
                    }
                    else
                    {
                        errores.Add(persona.Nombre);
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, $"Error asignando personal {personalId}");
                    errores.Add($"ID {personalId}: {ex.Message}");
                }
            }

            // Mostrar resultados
            if (errores.Count == 0)
            {
                mensajeErrorAsignacion = $"✅ {asignadosExitosos} personal asignado exitosamente";
            }
            else
            {
                mensajeErrorAsignacion = $"✅ {asignadosExitosos} asignados. Errores: {string.Join(", ", errores.Take(3))}";
                if (errores.Count > 3) mensajeErrorAsignacion += "...";
            }

            // Recargar datos si hubo asignaciones exitosas
            if (asignadosExitosos > 0)
            {
                await CargarDatos();
                CerrarModalAsignar();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, $"Error en asignación múltiple para turno {turnoSeleccionadoId}");
            mensajeErrorAsignacion = $"Error: {ex.Message}";
        }
        finally
        {
            asignandoPersonal = false;
            StateHasChanged();
        }
    }

