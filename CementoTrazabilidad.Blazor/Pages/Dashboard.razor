@page "/dashboard"
@layout MainLayout
@attribute [Authorize]
@using CementoTrazabilidad.Shared.DTOs
@using System.Net.Http.Json
@inject ITurnoService TurnoService
@inject IMetricasService MetricasService
@inject HttpClient Http
@inject ILogger<Dashboard> Logger
@inject IJSRuntime JSRuntime

<PageTitle>Dashboard - CementoTrazabilidad</PageTitle>

<div class="container-fluid">
    <!-- Encabezado -->
    <div class="row mb-4">
        <div class="col">
            <h1><i class="fas fa-tachometer-alt me-2"></i>Dashboard de Producción</h1>
            <p class="text-muted">Métricas en tiempo real según estándares de producción</p>
        </div>
        <div class="col-auto">
            <small class="text-muted">Última actualización: @ultimaActualizacion.ToString("HH:mm:ss")</small>
            <button class="btn btn-sm btn-outline-primary ms-2" @onclick="CargarDatos">
                <i class="fas fa-sync-alt @(cargando ? "fa-spin" : "")"></i> Actualizar
            </button>
            
            @if (turnoActual != null)
            {
                <button class="btn btn-sm btn-success ms-2" @onclick="ExportarTurnoActual">
                    <i class="fas fa-file-excel me-1"></i> Exportar Turno
                </button>
            }
            
            @if (turnosHoy.Count >= 3)
            {
                <button class="btn btn-sm btn-primary ms-2" @onclick="ExportarDiario">
                    <i class="fas fa-calendar-check me-1"></i> Exportar Día Completo
                </button>
            }
        </div>
    </div>

    @if (cargando && primeraVez)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="mt-2">Cargando dashboard...</p>
        </div>
    }
    else
    {
        <!-- ✅ SECCIÓN 1: KPIs PRINCIPALES -->
        <div class="row mb-4">
            <div class="col-xl-3 col-md-6 mb-3">
                <div class="card border-left-primary shadow h-100">
                    <div class="card-body">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                            Turno Actual
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            @if (turnoActual != null)
                            {
                                <span>Turno @turnoActual.TurnoNumero 🟢</span>
                                <br />
                                <small class="text-muted">@ObtenerHorarioTurno(turnoActual.TurnoNumero)</small>
                            }
                            else
                            {
                                <span class="text-muted">Sin turno activo</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-3">
                <div class="card border-left-success shadow h-100">
                    <div class="card-body">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                            Factor de Corrección (FC)
                        </div>
                        <div class="h5 mb-0 font-weight-bold">
                            @if (metricas != null)
                            {
                                <span class="@GetColorCumplimiento(metricas.FactorCorreccion)">
                                    @metricas.FactorCorreccion.ToString("N2")%
                                </span>
                                <br />
                                <small class="text-muted">Objetivo: ≥90%</small>
                            }
                            else
                            {
                                <span class="text-muted">--</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-3">
                <div class="card border-left-info shadow h-100">
                    <div class="card-body">
                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                            Factor de Producción (FP)
                        </div>
                        <div class="h5 mb-0 font-weight-bold">
                            @if (metricas != null)
                            {
                                <span class="@GetColorCumplimiento(metricas.FactorProduccion)">
                                    @metricas.FactorProduccion.ToString("N2")%
                                </span>
                                <br />
                                <small class="text-muted">vs Objetivo 80 Tn/h</small>
                            }
                            else
                            {
                                <span class="text-muted">--</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-3">
                <div class="card border-left-warning shadow h-100">
                    <div class="card-body">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                            Producción
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            @if (metricas != null)
                            {
                                <span>@metricas.BolsasRealizadas bolsas</span>
                                <br />
                                <small class="text-muted">@metricas.ToneladasPorHora.ToString("N1") Tn/h</small>
                            }
                            else
                            {
                                <span class="text-muted">--</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ✅ SECCIÓN 2: TABLA DE MÉTRICAS ESTILO EXCEL -->
        @if (turnoActual != null && metricas != null)
        {
            <div class="row mb-4">
                <div class="col-lg-6">
                    <div class="card shadow">
                        <div class="card-header bg-primary text-white">
                            <h6 class="mb-0">
                                <i class="fas fa-clock me-2"></i>Tiempos del Turno
                            </h6>
                        </div>
                        <div class="card-body">
                            <table class="table table-sm table-hover mb-0">
                                <tbody>
                                    <tr>
                                        <td class="fw-bold">Horas de Marcha</td>
                                        <td class="text-end">@FormatearHoras(metricas.HorasMarcha)</td>
                                        <td class="text-end text-muted">@metricas.HorasMarcha.TotalHours.ToString("N2")h</td>
                                    </tr>
                                    <tr class="table-success">
                                        <td class="fw-bold">Horas Productivas</td>
                                        <td class="text-end fw-bold">@FormatearHoras(metricas.HorasProductivas)</td>
                                        <td class="text-end fw-bold">@metricas.HorasProductivas.TotalHours.ToString("N2")h</td>
                                    </tr>
                                    <tr class="table-info">
                                        <td class="fw-bold">Objetivo Horas</td>
                                        <td class="text-end">@FormatearHoras(metricas.HorasProductivasObjetivo)</td>
                                        <td class="text-end">@metricas.HorasProductivasObjetivo.TotalHours.ToString("N2")h</td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Factor de Corrección (FC)</td>
                                        <td class="text-end" colspan="2">
                                            <span class="badge @GetBadgeCumplimiento(metricas.FactorCorreccion) fs-6">
                                                @metricas.FactorCorreccion.ToString("N2")%
                                            </span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Cumplimiento Horas</td>
                                        <td class="text-end" colspan="2">
                                            <span class="badge @GetBadgeCumplimiento(metricas.CumplimientoHoras) fs-6">
                                                @metricas.CumplimientoHoras.ToString("N2")%
                                            </span>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="card shadow">
                        <div class="card-header bg-success text-white">
                            <h6 class="mb-0">
                                <i class="fas fa-industry me-2"></i>Producción y Rendimiento
                            </h6>
                        </div>
                        <div class="card-body">
                            <table class="table table-sm table-hover mb-0">
                                <tbody>
                                    <tr>
                                        <td class="fw-bold">Bolsas Realizadas</td>
                                        <td class="text-end" colspan="2">
                                            <strong>@metricas.BolsasRealizadas.ToString("N0")</strong>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Toneladas Producidas</td>
                                        <td class="text-end" colspan="2">
                                            <strong>@metricas.ToneladasProducidas.ToString("N2") Tn</strong>
                                        </td>
                                    </tr>
                                    <tr class="table-success">
                                        <td class="fw-bold">Tn/h Real</td>
                                        <td class="text-end fw-bold">@metricas.ToneladasPorHora.ToString("N2")</td>
                                        <td class="text-end"></td>
                                    </tr>
                                    <tr class="table-info">
                                        <td class="fw-bold">Tn/h Objetivo</td>
                                        <td class="text-end">@metricas.ToneladasPorHoraObjetivo.ToString("N2")</td>
                                        <td class="text-end"></td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Factor de Producción (FP)</td>
                                        <td class="text-end" colspan="2">
                                            <span class="badge @GetBadgeCumplimiento(metricas.FactorProduccion) fs-6">
                                                @metricas.FactorProduccion.ToString("N2")%
                                            </span>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ✅ SECCIÓN 3: PARADAS CLASIFICADAS -->
            <div class="row mb-4">
                <div class="col-lg-8">
                    <div class="card shadow">
                        <div class="card-header bg-danger text-white">
                            <h6 class="mb-0">
                                <i class="fas fa-pause-circle me-2"></i>Paradas del Turno (Clasificadas)
                            </h6>
                        </div>
                        <div class="card-body">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Tipo de Parada</th>
                                        <th class="text-end">Tiempo (HH:MM)</th>
                                        <th class="text-end">Horas</th>
                                        <th class="text-end">Minutos</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><i class="fas fa-wrench text-danger me-2"></i>PARADAS MECÁNICAS</td>
                                        <td class="text-end">@FormatearMinutosHHMM(metricas.ParadasMecanicas)</td>
                                        <td class="text-end">@((metricas.ParadasMecanicas / 60).ToString("N2"))</td>
                                        <td class="text-end">@metricas.ParadasMecanicas.ToString("N0")</td>
                                    </tr>
                                    <tr>
                                        <td><i class="fas fa-bolt text-warning me-2"></i>PARADAS ELÉCTRICAS</td>
                                        <td class="text-end">@FormatearMinutosHHMM(metricas.ParadasElectricas)</td>
                                        <td class="text-end">@((metricas.ParadasElectricas / 60).ToString("N2"))</td>
                                        <td class="text-end">@metricas.ParadasElectricas.ToString("N0")</td>
                                    </tr>
                                    <tr>
                                        <td><i class="fas fa-user-cog text-info me-2"></i>PARADAS OPERATIVAS</td>
                                        <td class="text-end">@FormatearMinutosHHMM(metricas.ParadasOperativas)</td>
                                        <td class="text-end">@((metricas.ParadasOperativas / 60).ToString("N2"))</td>
                                        <td class="text-end">@metricas.ParadasOperativas.ToString("N0")</td>
                                    </tr>
                                    <tr>
                                        <td><i class="fas fa-question-circle text-secondary me-2"></i>Circunstanciales</td>
                                        <td class="text-end">@FormatearMinutosHHMM(metricas.ParadasCircunstanciales)</td>
                                        <td class="text-end">@((metricas.ParadasCircunstanciales / 60).ToString("N2"))</td>
                                        <td class="text-end">@metricas.ParadasCircunstanciales.ToString("N0")</td>
                                    </tr>
                                    <tr class="table-danger fw-bold">
                                        <td>TOTAL PARADAS</td>
                                        <td class="text-end">@FormatearHoras(metricas.TotalParadas)</td>
                                        <td class="text-end">@metricas.TotalParadas.TotalHours.ToString("N2")</td>
                                        <td class="text-end">@metricas.TotalParadas.TotalMinutes.ToString("N0")</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card shadow">
                        <div class="card-header bg-warning text-dark">
                            <h6 class="mb-0">
                                <i class="fas fa-pallet me-2"></i>Andenes y Palets
                            </h6>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="text-xs text-uppercase fw-bold text-muted">
                                    Cantidad Andenes
                                    <i class="fas fa-info-circle text-muted ms-1" 
                                       title="Valor variable según demanda del cliente" 
                                       data-bs-toggle="tooltip"></i>
                                </label>
                                <h3 class="mb-0">@metricas.CantidadAndenes</h3>
                                <small class="text-muted">
                                    <i class="fas fa-box me-1"></i>
                                    ~@((metricas.CantidadAndenes > 0 ? metricas.BolsasNetas / metricas.CantidadAndenes : 0).ToString("N0")) bolsas/andén
                                </small>
                            </div>
                            <hr />
                            <div class="row">
                                <div class="col-6">
                                    <label class="text-xs text-uppercase fw-bold text-muted">Palets Real</label>
                                    <h4 class="mb-0">@metricas.PaletsRealizados</h4>
                                </div>
                                <div class="col-6">
                                    <label class="text-xs text-uppercase fw-bold text-muted">Objetivo</label>
                                    <h4 class="mb-0 text-muted">@metricas.PaletsObjetivoTurno</h4>
                                </div>
                            </div>
                            <div class="progress mt-3" style="height: 25px;">
                                <div class="progress-bar @GetColorBarraCumplimiento(metricas.CumplimientoPalets)" 
                                     role="progressbar" 
                                     style="width: @Math.Min(metricas.CumplimientoPalets, 100)%">
                                    @metricas.CumplimientoPalets.ToString("N1")%
                                </div>
                            </div>
                            <small class="text-muted">
                                <i class="fas fa-info-circle me-1"></i>
                                Objetivo diario: @metricas.PaletsObjetivoDiario palets
                            </small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ✅ NUEVA SECCIÓN: CONSUMO DE BOLSAS DETALLADO -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card shadow">
                        <div class="card-header bg-primary text-white">
                            <h6 class="mb-0">
                                <i class="fas fa-box-open me-2"></i>Consumo de Bolsas - Detalle del Turno
                            </h6>
                        </div>
                        <div class="card-body">
                            @if (consumosDetallados != null && consumosDetallados.Any())
                            {
                                <div class="row mb-3">
                                    <div class="col-md-3">
                                        <div class="card bg-light">
                                            <div class="card-body text-center">
                                                <h6 class="text-muted mb-2">Total Bolsas</h6>
                                                <h3 class="mb-0 text-primary">@consumosDetallados.Sum(c => c.CantidadBolsas).ToString("N0")</h3>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="card bg-light">
                                            <div class="card-body text-center">
                                                <h6 class="text-muted mb-2">Defectuosas</h6>
                                                <h3 class="mb-0 text-warning">@consumosDetallados.Sum(c => c.BolsasDefectuosas).ToString("N0")</h3>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="card bg-light">
                                            <div class="card-body text-center">
                                                <h6 class="text-muted mb-2">Bolsas C32</h6>
                                                <h3 class="mb-0 text-info">@consumosDetallados.Where(c => c.TipoCemento == "C32").Sum(c => c.CantidadBolsas).ToString("N0")</h3>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="card bg-light">
                                            <div class="card-body text-center">
                                                <h6 class="text-muted mb-2">Bolsas F40</h6>
                                                <h3 class="mb-0 text-success">@consumosDetallados.Where(c => c.TipoCemento == "F40").Sum(c => c.CantidadBolsas).ToString("N0")</h3>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="table-responsive">
                                    <table class="table table-sm table-hover">
                                        <thead class="table-light">
                                            <tr>
                                                <th><i class="fas fa-clock me-1"></i>Fecha/Hora</th>
                                                <th><i class="fas fa-truck me-1"></i>Proveedor</th>
                                                <th><i class="fas fa-cube me-1"></i>Tipo Cemento</th>
                                                <th class="text-end"><i class="fas fa-box me-1"></i>Cantidad</th>
                                                <th class="text-end"><i class="fas fa-exclamation-triangle me-1"></i>Defectuosas</th>
                                                <th><i class="fas fa-barcode me-1"></i>Lote</th>
                                                <th><i class="fas fa-comment me-1"></i>Observaciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var consumo in consumosDetallados.OrderByDescending(c => c.FechaConsumo))
                                            {
                                                <tr>
                                                    <td class="text-nowrap">
                                                        <small>@consumo.FechaConsumo.ToString("dd/MM HH:mm")</small>
                                                    </td>
                                                    <td>
                                                        <strong>@consumo.ProveedorNombre</strong>
                                                        @if (!string.IsNullOrEmpty(consumo.MaterialDescripcion))
                                                        {
                                                            <br /><small class="text-muted">@consumo.MaterialDescripcion</small>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (!string.IsNullOrEmpty(consumo.TipoCemento))
                                                        {
                                                            var badgeColor = consumo.TipoCemento == "C32" ? "bg-info" : "bg-success";
                                                            <span class="badge @badgeColor">@consumo.TipoCemento</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">-</span>
                                                        }
                                                    </td>
                                                    <td class="text-end">
                                                        <strong class="text-primary">@consumo.CantidadBolsas.ToString("N0")</strong>
                                                    </td>
                                                    <td class="text-end">
                                                        @if (consumo.BolsasDefectuosas > 0)
                                                        {
                                                            <span class="badge bg-warning text-dark">@consumo.BolsasDefectuosas</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">0</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (!string.IsNullOrEmpty(consumo.LoteBolsa))
                                                        {
                                                            <code class="small">@consumo.LoteBolsa</code>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">-</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        <small class="text-muted">@(consumo.Observaciones ?? "-")</small>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot class="table-active">
                                            <tr class="fw-bold">
                                                <td colspan="3" class="text-end">TOTALES:</td>
                                                <td class="text-end text-primary fs-5">@consumosDetallados.Sum(c => c.CantidadBolsas).ToString("N0")</td>
                                                <td class="text-end text-warning fs-5">@consumosDetallados.Sum(c => c.BolsasDefectuosas).ToString("N0")</td>
                                                <td colspan="2"></td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info mb-0">
                                    <i class="fas fa-info-circle me-2"></i>
                                    No hay consumos de bolsas registrados para este turno.
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- ✅ SECCIÓN 4: DISTRIBUCIÓN DEL TIEMPO (COMPUESTO C32) -->
            <div class="row mb-4">
                <div class="col-lg-6">
                    <div class="card shadow">
                        <div class="card-header bg-info text-white">
                            <h6 class="mb-0">
                                <i class="fas fa-chart-pie me-2"></i>Distribución del Tiempo
                            </h6>
                        </div>
                        <div class="card-body">
                            @if (distribucionTiempo != null && distribucionTiempo.Any())
                            {
                                <table class="table table-sm table-hover mb-3">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Actividad</th>
                                            <th class="text-end">Tiempo</th>
                                            <th class="text-end">Horas</th>
                                            <th class="text-end">%</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in distribucionTiempo.OrderByDescending(d => d.Minutos))
                                        {
                                            <tr>
                                                <td>
                                                    <span class="badge" style="background-color: @item.Color;">●</span>
                                                    @item.Actividad
                                                </td>
                                                <td class="text-end">@FormatearMinutosHHMM(item.Minutos)</td>
                                                <td class="text-end">@item.Horas.ToString("N2")</td>
                                                <td class="text-end fw-bold">@item.Porcentaje.ToString("N1")%</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                                <canvas id="chartDistribucionTiempo" style="max-height: 250px;"></canvas>
                            }
                            else
                            {
                                <p class="text-muted text-center">No hay datos de distribución</p>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="card shadow">
                        <div class="card-header bg-warning text-dark">
                            <h6 class="mb-0">
                                <i class="fas fa-chart-bar me-2"></i>Paradas por Tipo (Detalle)
                            </h6>
                        </div>
                        <div class="card-body">
                            <canvas id="chartParadasDetalladas" style="max-height: 350px;"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ✅ SECCIÓN 5: COMPARACIÓN CON OBJETIVOS -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card shadow">
                        <div class="card-header bg-primary text-white">
                            <h6 class="mb-0">
                                <i class="fas fa-crosshairs me-2"></i>Cumplimiento de Objetivos
                            </h6>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <h6 class="text-muted">Producción (Tn/h)</h6>
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span>Real: <strong>@metricas.ToneladasPorHora.ToString("N2")</strong></span>
                                        <span class="text-muted">Obj: @metricas.ToneladasPorHoraObjetivo</span>
                                    </div>
                                    <div class="progress" style="height: 30px;">
                                        <div class="progress-bar @GetColorBarraCumplimiento(metricas.CumplimientoProduccion)" 
                                             style="width: @Math.Min(metricas.CumplimientoProduccion, 100)%">
                                            @metricas.CumplimientoProduccion.ToString("N1")%
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-4 mb-3">
                                    <h6 class="text-muted">Horas Productivas</h6>
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span>Real: <strong>@metricas.HorasProductivas.TotalHours.ToString("N2")h</strong></span>
                                        <span class="text-muted">Obj: @metricas.HorasProductivasObjetivo.TotalHours.ToString("N1")h</span>
                                    </div>
                                    <div class="progress" style="height: 30px;">
                                        <div class="progress-bar @GetColorBarraCumplimiento(metricas.CumplimientoHoras)" 
                                             style="width: @Math.Min(metricas.CumplimientoHoras, 100)%">
                                            @metricas.CumplimientoHoras.ToString("N1")%
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-4 mb-3">
                                    <h6 class="text-muted">Palets del Turno</h6>
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span>Real: <strong>@metricas.PaletsRealizados</strong></span>
                                        <span class="text-muted">Obj: @metricas.PaletsObjetivoTurno</span>
                                    </div>
                                    <div class="progress" style="height: 30px;">
                                        <div class="progress-bar @GetColorBarraCumplimiento(metricas.CumplimientoPalets)" 
                                             style="width: @Math.Min(metricas.CumplimientoPalets, 100)%">
                                            @metricas.CumplimientoPalets.ToString("N1")%
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- ✅ SECCIÓN 6: GRÁFICOS COMPARATIVOS -->
        <div class="row mb-4">
            <div class="col-lg-12">
                <div class="card shadow">
                    <div class="card-header bg-success text-white">
                        <h6 class="mb-0">
                            <i class="fas fa-chart-line me-2"></i>Comparación Real vs Objetivo
                        </h6>
                    </div>
                    <div class="card-body">
                        <canvas id="chartComparacion" style="max-height: 300px;"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- ✅ NUEVA SECCIÓN: ACTIVIDAD EN TIEMPO REAL -->
        @if (turnoActual != null && historialEventosCarga != null && historialEventosCarga.Any())
        {
            var ultimoEvento = historialEventosCarga.OrderByDescending(e => e.FechaHora).FirstOrDefault();
            
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card shadow border-left-info">
                        <div class="card-header bg-gradient-info text-white">
                            <h6 class="mb-0">
                                <i class="fas fa-broadcast-tower me-2 fa-pulse"></i>
                                Actividad en Tiempo Real
                            </h6>
                        </div>
                        <div class="card-body">
                            @if (ultimoEvento != null)
                            {
                                var iconoEvento = ultimoEvento.TipoEvento == "ANDEN" ? "fa-warehouse" : "fa-boxes-stacked";
                                var colorEvento = ultimoEvento.TipoEvento == "ANDEN" ? "primary" : "success";
                                
                                <div class="row align-items-center">
                                    <div class="col-md-2 text-center">
                                        <i class="fas @iconoEvento fa-3x text-@colorEvento"></i>
                                    </div>
                                    <div class="col-md-6">
                                        <h4 class="mb-1">
                                            <span class="badge bg-@colorEvento">@ultimoEvento.TipoEvento</span>
                                            @ultimoEvento.ZonaCarga
                                        </h4>
                                        <p class="mb-1">
                                            <i class="fas fa-clock me-1"></i>
                                            <strong>Última actividad:</strong> @ultimoEvento.FechaHora.ToString("HH:mm:ss")
                                        </p>
                                        @if (!string.IsNullOrEmpty(ultimoEvento.Observaciones))
                                        {
                                            <p class="text-muted mb-0">
                                                <i class="fas fa-comment me-1"></i>@ultimoEvento.Observaciones
                                            </p>
                                        }
                                    </div>
                                    <div class="col-md-4">
                                        <div class="alert alert-info mb-0">
                                            <i class="fas fa-info-circle me-1"></i>
                                            <strong>Tipo de carga:</strong> @ultimoEvento.TipoCarga
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="text-center text-muted py-3">
                                    <i class="fas fa-pause-circle fa-2x mb-2"></i>
                                    <p>No hay actividad reciente registrada</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Historial reciente de eventos -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card shadow">
                        <div class="card-header bg-secondary text-white">
                            <h6 class="mb-0">
                                <i class="fas fa-history me-2"></i>Historial de Eventos de Carga
                            </h6>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th><i class="fas fa-calendar-alt me-1"></i>Fecha/Hora</th>
                                            <th><i class="fas fa-tag me-1"></i>Tipo</th>
                                            <th><i class="fas fa-location-dot me-1"></i>Zona</th>
                                            <th><i class="fas fa-truck-loading me-1"></i>Tipo Carga</th>
                                            <th><i class="fas fa-comment-dots me-1"></i>Observaciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var evento in historialEventosCarga.OrderByDescending(e => e.FechaHora).Take(20))
                                        {
                                            var badgeClass = evento.TipoEvento == "ANDEN" ? "bg-primary" : "bg-success";
                                            var iconClass = evento.TipoEvento == "ANDEN" ? "fa-warehouse" : "fa-boxes-stacked";
                                            
                                            <tr>
                                                <td class="text-nowrap">
                                                    <small>@evento.FechaHora.ToString("dd/MM HH:mm:ss")</small>
                                                </td>
                                                <td>
                                                    <span class="badge @badgeClass">
                                                        <i class="fas @iconClass me-1"></i>@evento.TipoEvento
                                                    </span>
                                                </td>
                                                <td><strong>@evento.ZonaCarga</strong></td>
                                                <td>
                                                    <span class="badge bg-info">@evento.TipoCarga</span>
                                                </td>
                                                <td>
                                                    <small class="text-muted">@(evento.Observaciones ?? "-")</small>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Sección de Registro de Lotes -->
        @if (turnoActual != null)
        {
            <div class="row">
                <div class="col-lg-12 mb-4">
                    <div class="card shadow border-left-success">
                        <div class="card-header bg-success text-white">
                            <h6 class="mb-0"><i class="fas fa-list-alt me-2"></i>Registro de Lotes</h6>
                        </div>
                        <div class="card-body">
                            <h4>
                                <span class="badge bg-success fs-5">@lotesTurnoActual.Count</span> lote(s) registrado(s)
                            </h4>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private bool cargando = false;
    private bool primeraVez = true;
    private DateTime ultimaActualizacion = DateTime.Now;
    private bool _graficosRenderizados = false;

    private TurnoDto? turnoActual;
    private List<TurnoDto> turnosHoy = new();
    private MetricasTurnoDto? metricas;
    private List<ParadasDetalladasDto> paradasDetalladas = new();
    private List<DistribucionTiempoDto> distribucionTiempo = new();
    
    // Datos existentes
    private List<EventoCargaHistorialDto>? historialEventosCarga = new();
    private List<ParadaDto> paradasTurnoActual = new();
    private Dictionary<int, int> cantidadPersonalPorTurno = new();
    private int personalEnTurnoActual = 0;
    private int consumoBolsas = 0;
    private List<LoteDto> lotesTurnoActual = new();
    private List<ConsumoBolsasDTO> consumosDetallados = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        primeraVez = false;
    }

    private async Task CargarDatos()
    {
        if (cargando) return;
        cargando = true;
        
        // ✅ Resetear flag de gráficos para forzar re-renderizado
        _graficosRenderizados = false;

        try
        {
            var todosTurnos = await TurnoService.GetTurnosAsync();
            var hoy = DateOnly.FromDateTime(DateTime.Today);
            turnosHoy = todosTurnos.Where(t => t.Fecha == hoy).OrderBy(t => t.TurnoNumero).ToList();
            turnoActual = turnosHoy.FirstOrDefault(t => t.Estado == "En Proceso");

            if (turnoActual != null)
            {
                Logger.LogInformation($"🔄 Cargando datos para turno {turnoActual.TurnoProduccionID}");
                
                // ✅ Cargar métricas avanzadas
                metricas = await MetricasService.GetMetricasTurnoAsync(turnoActual.TurnoProduccionID);
                paradasDetalladas = await MetricasService.GetParadasDetalladasAsync(turnoActual.TurnoProduccionID);
                distribucionTiempo = await MetricasService.GetDistribucionTiempoAsync(turnoActual.TurnoProduccionID);

                Logger.LogInformation($"📊 Métricas cargadas: BolsasRealizadas={metricas?.BolsasRealizadas}, Distribución={distribucionTiempo?.Count}");

                // Cargar datos existentes
                await Task.WhenAll(
                    CargarHistorialCarga(),
                    CargarParadasTurnoActual(),
                    CargarDashboardData()
                );

                personalEnTurnoActual = await ObtenerCantidadPersonal(turnoActual.TurnoProduccionID);
                
                Logger.LogInformation($"✅ Datos cargados: Lotes={lotesTurnoActual.Count}, Bolsas={consumoBolsas}, Eventos={historialEventosCarga?.Count ?? 0}");
            }
            else
            {
                Logger.LogWarning("⚠️ No hay turno activo");
            }

            await CargarCantidadPersonalPorTurno();
            ultimaActualizacion = DateTime.Now;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "❌ Error al cargar datos del dashboard");
        }
        finally
        {
            cargando = false;
            StateHasChanged();

            // ✅ Renderizar gráficos con validación
            await Task.Delay(500); // Dar tiempo al DOM
            await RenderizarGraficos();
        }
    }

    // ✅ CORREGIR: Usar endpoint alternativo o manejar error
    private async Task CargarHistorialCarga()
    {
        try
        {
            if (turnoActual == null) return;
            
            Logger.LogInformation($"📥 Cargando historial de eventos para turno {turnoActual.TurnoProduccionID}");
            
            // ✅ CORRECCIÓN: Usar endpoint /historial en lugar de base
            var response = await Http.GetFromJsonAsync<ApiResponse<List<EventoCargaHistorialDto>>>(
                $"api/eventocarga/turno/{turnoActual.TurnoProduccionID}/historial");
            
            if (response != null && response.Success && response.Data != null)
            {
                historialEventosCarga = response.Data;
                Logger.LogInformation($"✅ Cargados {historialEventosCarga.Count} eventos de carga");
            }
            else
            {
                historialEventosCarga = new List<EventoCargaHistorialDto>();
                Logger.LogWarning($"⚠️ No se pudieron cargar eventos: {response?.Message}");
            }
        }
        catch (HttpRequestException httpEx)
        {
            Logger.LogError(httpEx, $"⚠️ Error HTTP al cargar eventos: {httpEx.Message}");
            historialEventosCarga = new List<EventoCargaHistorialDto>();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "❌ Error al cargar historial de carga");
            historialEventosCarga = new List<EventoCargaHistorialDto>();
        }
    }

    private async Task CargarParadasTurnoActual()
    {
        try
        {
            if (turnoActual == null) return;
            
            paradasTurnoActual = await TurnoService.GetParadasTurnoAsync(turnoActual.TurnoProduccionID);
            Logger.LogInformation($"✅ Cargadas {paradasTurnoActual.Count} paradas");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "❌ Error al cargar paradas");
            paradasTurnoActual = new List<ParadaDto>();
        }
    }

    private async Task CargarDashboardData()
    {
        try
        {
            if (turnoActual == null) return;
            
            Logger.LogInformation($"📦 Cargando lotes y consumos para turno {turnoActual.TurnoProduccionID}");
            
            // ✅ Cargar lotes
            var responseLotes = await Http.GetFromJsonAsync<ApiResponse<List<LoteDto>>>(
                $"api/lotes/turno/{turnoActual.TurnoProduccionID}");
            
            if (responseLotes != null && responseLotes.Success)
            {
                lotesTurnoActual = responseLotes.Data ?? new List<LoteDto>();
                Logger.LogInformation($"✅ Lotes cargados: {lotesTurnoActual.Count}");
            }
            else
            {
                lotesTurnoActual = new List<LoteDto>();
                Logger.LogWarning($"⚠️ Error al cargar lotes: {responseLotes?.Message}");
            }
            
            // ✅ CORREGIDO: Cargar consumo de bolsas (devuelve List directamente, NO ApiResponse)
            try
            {
                var consumosDirectos = await Http.GetFromJsonAsync<List<ConsumoBolsasDTO>>(
                    $"api/ConsumoBolsas/turno/{turnoActual.TurnoProduccionID}");
                
                if (consumosDirectos != null)
                {
                    consumosDetallados = consumosDirectos;
                    consumoBolsas = consumosDetallados.Sum(c => c.CantidadBolsas);
                    Logger.LogInformation($"✅ Consumo de bolsas cargado: {consumoBolsas} bolsas, {consumosDetallados.Count} registros");
                }
                else
                {
                    consumosDetallados = new List<ConsumoBolsasDTO>();
                    consumoBolsas = 0;
                    Logger.LogWarning("⚠️ Respuesta de consumos es null");
                }
            }
            catch (Exception exConsumo)
            {
                Logger.LogError(exConsumo, "❌ Error al cargar consumo de bolsas");
                consumosDetallados = new List<ConsumoBolsasDTO>();
                consumoBolsas = 0;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "❌ Error general al cargar datos del dashboard");
            lotesTurnoActual = new List<LoteDto>();
            consumosDetallados = new List<ConsumoBolsasDTO>();
            consumoBolsas = 0;
        }
    }

    private async Task CargarCantidadPersonalPorTurno()
    {
        try
        {
            foreach (var turno in turnosHoy)
            {
                var personal = await TurnoService.GetPersonalTurnoAsync(turno.TurnoProduccionID);
                cantidadPersonalPorTurno[turno.TurnoProduccionID] = personal.Count;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "❌ Error al cargar personal por turno");
        }
    }

    private async Task<int> ObtenerCantidadPersonal(int turnoId)
    {
        try
        {
            var personal = await TurnoService.GetPersonalTurnoAsync(turnoId);
            return personal.Count;
        }
        catch
        {
            return 0;
        }
    }

    private int GetCantidadPersonal(int turnoId)
    {
        return cantidadPersonalPorTurno.TryGetValue(turnoId, out var cantidad) ? cantidad : 0;
    }

    private async Task RenderizarGraficos()
    {
        try
        {
            Logger.LogInformation("🎨 Iniciando renderizado de gráficos...");
            
            // ✅ Validar que haya datos antes de renderizar
            if (metricas == null)
            {
                Logger.LogWarning("⚠️ No hay métricas para renderizar gráficos");
                return;
            }

            await JSRuntime.InvokeVoidAsync("limpiarGraficos");

            // ✅ Gráfico de distribución (solo si hay datos)
            if (distribucionTiempo != null && distribucionTiempo.Any())
            {
                Logger.LogInformation($"📊 Renderizando gráfico de distribución con {distribucionTiempo.Count} elementos");
                
                await JSRuntime.InvokeVoidAsync("renderizarGraficoDistribucion",
                    distribucionTiempo.Select(d => d.Actividad).ToArray(),
                    distribucionTiempo.Select(d => (double)d.Minutos).ToArray(),
                    distribucionTiempo.Select(d => d.Color).ToArray()
                );
            }
            else
            {
                Logger.LogWarning("⚠️ No hay datos de distribución del tiempo");
            }

            // ✅ Gráfico de paradas detalladas
            Logger.LogInformation("📊 Renderizando gráfico de paradas detalladas");
            
            await JSRuntime.InvokeVoidAsync("renderizarGraficoParadasDetalladas",
                new[] { "Mecánicas", "Eléctricas", "Operativas", "Circunstanciales" },
                new[] { metricas.ParadasMecanicas, metricas.ParadasElectricas, 
                        metricas.ParadasOperativas, metricas.ParadasCircunstanciales }
            );

            // ✅ Gráfico de comparación Real vs Objetivo
            Logger.LogInformation("📊 Renderizando gráfico de comparación");
            
            await JSRuntime.InvokeVoidAsync("renderizarGraficoComparacion",
                (double)metricas.ToneladasPorHora,
                (double)metricas.ToneladasPorHoraObjetivo,
                metricas.HorasProductivas.TotalHours,
                metricas.HorasProductivasObjetivo.TotalHours,
                metricas.PaletsRealizados,
                metricas.PaletsObjetivoTurno
            );

            _graficosRenderizados = true;
            Logger.LogInformation("✅ Gráficos renderizados exitosamente");
        }
        catch (JSException jsEx)
        {
            Logger.LogError(jsEx, $"❌ Error JavaScript al renderizar gráficos: {jsEx.Message}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "❌ Error general al renderizar gráficos");
        }
    }

    // Métodos helper para formateo y colores
    private string FormatearHoras(TimeSpan tiempo)
    {
        return $"{(int)tiempo.TotalHours:D2}:{tiempo.Minutes:D2}:{tiempo.Seconds:D2}";
    }

    private string FormatearMinutosHHMM(double minutos)
    {
        var tiempo = TimeSpan.FromMinutes(minutos);
        return $"{(int)tiempo.TotalHours:D2}:{tiempo.Minutes:D2}";
    }

    private string ObtenerHorarioTurno(int turnoNumero)
    {
        return turnoNumero switch
        {
            1 => "06:00 - 14:30 (8h 10m)",
            2 => "14:30 - 22:30 (7h 40m)",
            3 => "22:30 - 06:00 (7h 10m)",
            _ => "N/A"
        };
    }

    private string GetColorCumplimiento(decimal porcentaje)
    {
        return porcentaje switch
        {
            >= 90 => "text-success",
            >= 70 => "text-warning",
            _ => "text-danger"
        };
    }

    private string GetBadgeCumplimiento(decimal porcentaje)
    {
        return porcentaje switch
        {
            >= 90 => "bg-success",
            >= 70 => "bg-warning",
            _ => "bg-danger"
        };
    }

    private string GetColorBarraCumplimiento(decimal porcentaje)
    {
        return porcentaje switch
        {
            >= 90 => "bg-success",
            >= 70 => "bg-warning",
            _ => "bg-danger"
        };
    }

    public class ApiResponse<T>
    {
        public bool Success { get; set; }
        public T? Data { get; set; }
        public string? Message { get; set; }
    }

    private async Task ExportarTurnoActual()
    {
        if (turnoActual == null) return;
        
        try
        {
            var url = $"{Http.BaseAddress}api/export/dashboard/turno/{turnoActual.TurnoProduccionID}";
            await JSRuntime.InvokeVoidAsync("open", url, "_blank");
            Logger.LogInformation($"✅ Exportando turno {turnoActual.TurnoProduccionID} a Excel");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "❌ Error al exportar turno");
            await JSRuntime.InvokeVoidAsync("alert", $"Error al exportar: {ex.Message}");
        }
    }

    private async Task ExportarDiario()
    {
        try
        {
            var fecha = DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd");
            var url = $"{Http.BaseAddress}api/export/dashboard/diario/{fecha}";
            await JSRuntime.InvokeVoidAsync("open", url, "_blank");
            Logger.LogInformation($"✅ Exportando dashboard diario para {fecha}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "❌ Error al exportar dashboard diario");
            await JSRuntime.InvokeVoidAsync("alert", $"Error al exportar: {ex.Message}");
        }
    }

    private async Task ExportarMensual()
    {
        var año = DateTime.Now.Year;
        var mes = DateTime.Now.Month;
        
        var url = $"{Http.BaseAddress}api/export/dashboard/mensual/{año}/{mes}";
        await JSRuntime.InvokeVoidAsync("open", url, "_blank");
    }
}

