    // ==================== CONSUMO DE BOLSAS ====================

    private void AbrirModalConsumoBolsas()
    {
        mostrarModalConsumo = true;
    }

    private void CerrarModalConsumo()
    {
        mostrarModalConsumo = false;
        guardando = false;
    }

    private async Task EliminarConsumo(int consumoBolsasId)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", "¿Está seguro que desea eliminar este consumo?");
        if (!confirmado) return;

        try
        {
            var response = await Http.DeleteAsync($"api/consumosbolsas/{consumoBolsasId}");
            if (response.IsSuccessStatusCode)
            {
                consumosBolsas = await ConsumoBolsasService.GetConsumosByTurnoAsync(TurnoId);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al eliminar consumo");
            await JS.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
    }

    private async Task GuardarConsumo()
    {
        guardando = true;
        nuevoConsumo.TurnoProduccionID = TurnoId;

        try
        {
            var response = await Http.PostAsJsonAsync("api/consumosbolsas", nuevoConsumo);
            if (response.IsSuccessStatusCode)
            {
                consumosBolsas = await ConsumoBolsasService.GetConsumosByTurnoAsync(TurnoId);
                mostrarModalConsumo = false;
                nuevoConsumo = new ConsumoBolsasCreateDTO();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"Error: {error}");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al guardar consumo");
            await JS.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
        finally
        {
            guardando = false;
            StateHasChanged();
        }
    }

