    private string GetEstadoBadge(string estado)
    {
        return estado switch
        {
            "Programado" => "bg-secondary",
            "En Proceso" => "bg-success",
            "Finalizado" => "bg-primary",
            _ => "bg-info"
        };
    }

    private string CalcularDuracion()
    {
        if (turno == null || turno.FechaHoraInicio == default)
            return "-";

        if (turno.FechaHoraFin.HasValue)
        {
            var duracion = turno.FechaHoraFin.Value - turno.FechaHoraInicio;
            return $"{(int)duracion.TotalHours}h {duracion.Minutes}m";
        }
        else if (turno.Estado == "En Proceso")
        {
            var duracion = DateTime.Now - turno.FechaHoraInicio;
            return $"{(int)duracion.TotalHours}h {duracion.Minutes}m (en curso)";
        }

        return "-";
    }

    private string ObtenerHorarioTurno(int turnoNumero)
    {
        return turnoNumero switch
        {
            1 => "06:00 - 14:30",
            2 => "14:30 - 22:30",
            3 => "22:30 - 06:00",
            _ => "N/A"
        };
    }
