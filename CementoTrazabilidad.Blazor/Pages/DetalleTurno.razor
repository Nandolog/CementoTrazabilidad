    // ==================== MÉTODOS DE PARADAS ====================

    private async Task IniciarNuevaParada()
    {
        errorParada = "";

        if (string.IsNullOrWhiteSpace(nuevaParada.Tipo))
        {
            errorParada = "Debe seleccionar un tipo de parada";
            return;
        }

        if (string.IsNullOrWhiteSpace(nuevaParada.Motivo))
        {
            errorParada = "Debe ingresar el motivo de la parada";
            return;
        }

        if (string.IsNullOrWhiteSpace(nuevaParada.Descripcion))
        {
            errorParada = "Debe ingresar una descripción detallada";
            return;
        }

        iniciandoParada = true;
        StateHasChanged();

        try
        {
            nuevaParada.TurnoProduccionID = TurnoId;
            nuevaParada.FechaHoraInicio = DateTime.Now;
            nuevaParada.FechaHoraFin = null;

            var response = await Http.PostAsJsonAsync($"api/turnos/{TurnoId}/paradas", nuevaParada);

            if (response.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", "✅ Parada iniciada correctamente");
                InicializarNuevaParada();
                await CargarParadaActiva();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorParada = $"Error: {error}";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al iniciar parada");
            errorParada = $"Error: {ex.Message}";
        }
        finally
        {
            iniciandoParada = false;
            StateHasChanged();
        }
    }

    private async Task FinalizarParadaActiva()
    {
        if (paradaActiva == null) return;

        try
        {
            var response = await Http.PutAsJsonAsync(
                $"api/parada/{paradaActiva.ParadaID}/finalizar",
                new { FechaHoraFin = DateTime.Now });

            if (response.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", "✅ Producción reanudada");
                paradaActiva = null;
                await CargarParadaActiva();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al finalizar parada");
            await JS.InvokeVoidAsync("alert", $"❌ Error: {ex.Message}");
        }
    }

