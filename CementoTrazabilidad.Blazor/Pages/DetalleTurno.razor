@page "/turno/{TurnoId:int}"
@layout MainLayout
@attribute [Authorize]
@using CementoTrazabilidad.Shared.DTOs
@using CementoTrazabilidad.Blazor
@using System.Net.Http.Json
@inject ITurnoService TurnoService
@inject IPersonalService PersonalService
@inject IConsumoBolsasService ConsumoBolsasService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<DetalleTurno> Logger
@inject HttpClient Http

<PageTitle>Detalle de Turno - CementoTrazabilidad</PageTitle>

<div class="container-fluid">
    @if (cargando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Cargando detalles del turno...</p>
        </div>
    }
    else if (turno == null)
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-triangle me-2"></i>
            Turno no encontrado
        </div>
    }
    else
    {
        <!-- Encabezado con acciones -->
        <div class="d-flex justify-content-between align-items-start mb-4">
            <div>
                <h1>
                    <i class="fas fa-clock me-2"></i>
                    Turno @turno.TurnoNumero - @turno.Fecha.ToString("dd/MM/yyyy")
                </h1>
                <p class="text-muted mb-0">ID: @turno.TurnoProduccionID</p>
            </div>
            <div>
                <span class="badge @GetEstadoBadge(turno.Estado) fs-6 px-3 py-2">
                    @turno.Estado
                </span>
            </div>
        </div>

        <!-- Tarjetas de información -->
        <div class="row">
            <!-- Información básica -->
            <div class="col-md-4 mb-3">
                <div class="card h-100">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>Información del Turno</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-2">
                            <small class="text-muted">Fecha</small>
                            <p class="mb-0">@turno.Fecha.ToString("dddd, dd MMMM yyyy")</p>
                        </div>
                        <div class="mb-2">
                            <small class="text-muted">Número de Turno</small>
                            <p class="mb-0">@turno.TurnoNumero</p>
                        </div>
                        <div class="mb-2">
                            <small class="text-muted">Hora de Inicio</small>
                            <p class="mb-0">@(turno.FechaHoraInicio != default ? turno.FechaHoraInicio.ToString("HH:mm") : "-")</p>
                        </div>
                        <div class="mb-2">
                            <small class="text-muted">Hora de Fin</small>
                            <p class="mb-0">@(turno.FechaHoraFin?.ToString("HH:mm") ?? "-")</p>
                        </div>
                        <div class="mb-2">
                            <small class="text-muted">Duración</small>
                            <p class="mb-0">@CalcularDuracion()</p>
                        </div>
                        <div class="mb-2">
                            <small class="text-muted">Horario de Turno</small>
                            <p class="mb-0">@ObtenerHorarioTurno(turno.TurnoNumero)</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Personal asignado - ✅ CORREGIDO -->
            <div class="col-md-4 mb-3">
                <div class="card h-100">
                    <div class="card-header bg-light">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="mb-0"><i class="fas fa-users me-2"></i>Personal Asignado</h6>
                            <button class="btn btn-sm btn-outline-primary" @onclick="AbrirModalAsignarPersonal">
                                <i class="fas fa-edit"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        @if (personalTurno != null && personalTurno.Any())
                        {
                            <ul class="list-unstyled mb-0">
                                @foreach (var persona in personalTurno)
                                {
                                    <li class="mb-2 p-2 border rounded">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <i class="fas fa-user me-2 text-primary"></i>
                                                <strong>@persona.PersonalNombre</strong>
                                            </div>
                                            <span class="badge bg-secondary">@persona.RolTurno</span>
                                        </div>
                                        <small class="text-muted">Legajo: @persona.PersonalLegajo</small>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="text-center py-4">
                                <i class="fas fa-user-slash fa-2x text-muted mb-3"></i>
                                <p class="text-muted mb-0">No hay personal asignado</p>
                                <button class="btn btn-sm btn-primary mt-2" @onclick="AbrirModalAsignarPersonal">
                                    <i class="fas fa-user-plus me-2"></i>Asignar Personal
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Acciones rápidas -->
            <div class="col-md-4 mb-3">
                <div class="card h-100">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="fas fa-bolt me-2"></i>Acciones Rápidas</h6>
                    </div>
                    <div class="card-body d-flex flex-column">
                        @if (turno.Estado == "Programado")
                        {
                            <button class="btn btn-success mb-2" @onclick="IniciarTurno">
                                <i class="fas fa-play me-2"></i>Iniciar Turno
                            </button>
                        }

                        @if (turno.Estado == "En Proceso")
                        {
                            <button class="btn btn-danger mb-2" @onclick="FinalizarTurno">
                                <i class="fas fa-stop me-2"></i>Finalizar Turno
                            </button>
                        }

                        <button class="btn btn-primary mb-2" @onclick="RegistrarProduccion">
                            <i class="fas fa-industry me-2"></i>Registrar Producción
                        </button>

                        <button class="btn btn-info mb-2" @onclick="VerParadas">
                            <i class="fas fa-history me-2"></i>Ver Paradas
                        </button>

                        <button class="btn btn-outline-secondary mt-auto" @onclick="Volver">
                            <i class="fas fa-arrow-left me-2"></i>Volver a Producción
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sección de Consumo de Bolsas -->
        <div class="card mb-4">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-box-open me-2"></i>Consumo de Bolsas
                </h5>
                <button class="btn btn-light btn-sm" @onclick="AbrirModalConsumoBolsas">
                    <i class="fas fa-plus me-2"></i>Registrar Consumo
                </button>
            </div>
            <div class="card-body">
                @if (consumosBolsas.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover">
                            <thead>
                                <tr>
                                    <th>Fecha/Hora</th>
                                    <th>Proveedor</th>
                                    <th>Tipo Cemento</th>
                                    <th>Cantidad</th>
                                    <th>Defectuosas</th>
                                    <th>Lote</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var consumo in consumosBolsas)
                                {
                                    <tr>
                                        <td>@consumo.FechaConsumo.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@consumo.ProveedorNombre</td>
                                        <td><span class="badge bg-info">@(consumo.TipoCemento ?? "-")</span></td>
                                        <td><strong>@consumo.CantidadBolsas</strong></td>
                                        <td>
                                            @if (consumo.BolsasDefectuosas > 0)
                                            {
                                                <span class="badge bg-warning">@consumo.BolsasDefectuosas</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">0</span>
                                            }
                                        </td>
                                        <td>@(consumo.LoteBolsa ?? "-")</td>
                                        <td>
                                            <button class="btn btn-sm btn-danger" @onclick="() => EliminarConsumo(consumo.ConsumoBolsasID)">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="fw-bold table-active">
                                    <td colspan="3">TOTAL</td>
                                    <td>@consumosBolsas.Sum(c => c.CantidadBolsas) bolsas</td>
                                    <td>@consumosBolsas.Sum(c => c.BolsasDefectuosas) defectuosas</td>
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info mb-0">
                        <i class="fas fa-info-circle me-2"></i>
                        No hay consumo de bolsas registrado para este turno.
                    </div>
                }
            </div>
        </div>

        <!-- Control de Paradas Mejorado -->
        <div class="card mb-3">
            <div class="card-header bg-warning text-dark">
                <h6 class="mb-0"><i class="fas fa-pause-circle me-2"></i>Control de Paradas</h6>
            </div>
            <div class="card-body">
                @if (paradaActiva != null)
                {
                    <!-- HAY PARADA ACTIVA -->
                    <div class="alert alert-warning mb-3">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <strong>⏸️ Parada en curso</strong>
                                <p class="mb-1"><strong>Tipo:</strong> @paradaActiva.Tipo</p>
                                <p class="mb-1"><strong>Motivo:</strong> @(paradaActiva.Motivo ?? "-")</p>
                                <p class="mb-0"><small>Inicio: @paradaActiva.FechaHoraInicio.ToString("dd/MM/yyyy HH:mm:ss")</small></p>
                            </div>
                            <span class="badge bg-warning text-dark fs-6">Activa</span>
                        </div>
                    </div>

                    <button class="btn btn-success btn-lg w-100" @onclick="FinalizarParadaActiva">
                        <i class="fas fa-play me-2"></i>Reanudar Producción
                    </button>
                }
                else
                {
                    <!-- NO HAY PARADA ACTIVA - FORMULARIO COMPLETO -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Tipo de Parada *</label>
                            <select class="form-select" @bind="nuevaParada.Tipo">
                                <option value="">Seleccione...</option>
                                <option value="Circunstancial">🌐 Circunstancial</option>
                                <option value="Operativa">⚙️ Operativa</option>
                                <option value="Mecanica">🔧 Mecánica</option>
                                <option value="Electrica">⚡ Eléctrica</option>
                                <option value="Stock Lleno">📦 Stock Lleno</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Motivo *</label>
                            <input type="text" class="form-control" @bind="nuevaParada.Motivo"
                                   placeholder="Ej: Falla en motor principal" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Descripción Detallada *</label>
                        <textarea class="form-control" @bind="nuevaParada.Descripcion" rows="3"
                                  placeholder="Describa en detalle lo ocurrido..."></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Acciones Correctivas (Opcional)</label>
                        <textarea class="form-control" @bind="nuevaParada.AccionesCorrectivas" rows="2"
                                  placeholder="Acciones tomadas para resolver el problema..."></textarea>
                        <small class="form-text text-muted">Se puede completar después de finalizar la parada</small>
                    </div>

                    @if (!string.IsNullOrEmpty(errorParada))
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-triangle me-2"></i>@errorParada
                        </div>
                    }

                    <button class="btn btn-warning btn-lg w-100" @onclick="IniciarNuevaParada" disabled="@iniciandoParada">
                        @if (iniciandoParada)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Iniciando...</span>
                        }
                        else
                        {
                            <i class="fas fa-pause me-2"></i>
                            <span>Iniciar Parada</span>
                        }
                    </button>
                }
            </div>
        </div>
    }
</div>

<!-- Modal para registrar consumo de bolsas -->
@if (mostrarModalConsumo)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Registrar Consumo de Bolsas</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModalConsumo"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="nuevoConsumo" OnValidSubmit="GuardarConsumo">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label">Proveedor de Bolsas *</label>
                            <select class="form-select" @bind="nuevoConsumo.ProveedorBolsaID" required>
                                <option value="0">Seleccione proveedor...</option>
                                @foreach (var proveedor in proveedores)
                                {
                                    <option value="@proveedor.ProveedorBolsaID">@proveedor.Nombre</option>
                                }
                            </select>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Cantidad de Bolsas *</label>
                                <input type="number" class="form-control" @bind="nuevoConsumo.CantidadBolsas" required min="1" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Bolsas Defectuosas</label>
                                <input type="number" class="form-control" @bind="nuevoConsumo.BolsasDefectuosas" min="0" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Tipo de Cemento</label>
                            <select class="form-select" @bind="nuevoConsumo.TipoCemento">
                                <option value="">Seleccione...</option>
                                <option value="C32">C32</option>
                                <option value="F40">F40</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Lote de Bolsas</label>
                            <input type="text" class="form-control" @bind="nuevoConsumo.LoteBolsa" maxlength="50" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Observaciones</label>
                            <textarea class="form-control" @bind="nuevoConsumo.Observaciones" rows="3"></textarea>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <button type="button" class="btn btn-secondary" @onclick="CerrarModalConsumo">Cancelar</button>
                            <button type="submit" class="btn btn-primary" disabled="@guardando">
                                @if (guardando)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                Guardar
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- ✅ NUEVO MODAL - Asignar Personal -->
@if (mostrarModalAsignarPersonal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-user-plus me-2"></i>
                        Asignar Personal al Turno @TurnoId
                    </h5>
                    <button type="button" class="btn-close" @onclick="CerrarModalAsignar"></button>
                </div>

                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(mensajeErrorAsignacion))
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            @mensajeErrorAsignacion
                        </div>
                    }

                    @if (cargandoPersonalDisponible)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary"></div>
                            <p class="mt-2">Cargando personal...</p>
                        </div>
                    }
                    else if (personalDisponible.Count == 0)
                    {
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            Todo el personal disponible ya está asignado.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th width="50px"></th>
                                        <th>Legajo</th>
                                        <th>Nombre</th>
                                        <th>Rol</th>
                                        <th>Asignar como</th>
                                        <th>Acción</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var persona in personalDisponible)
                                    {
                                        <tr>
                                            <td>
                                                <input type="checkbox"
                                                       @bind="personalSeleccionadoIds[persona.PersonalID]"
                                                       disabled="@asignandoPersonal" />
                                            </td>
                                            <td><strong>@persona.Legajo</strong></td>
                                            <td>@persona.Nombre</td>
                                            <td>
                                                <span class="badge @GetRolBadge(persona.Rol)">
                                                    @persona.Rol
                                                </span>
                                            </td>
                                            <td>
                                                <select class="form-select form-select-sm"
                                                        @bind="rolesTurnoSeleccionados[persona.PersonalID]"
                                                        disabled="@asignandoPersonal">
                                                    <option value="Operario">Operario</option>
                                                    <option value="Supervisor">Supervisor</option>
                                                    <option value="Jefe de Turno">Jefe de Turno</option>
                                                    <option value="Ayudante">Ayudante</option>
                                                    <option value="Mantenimiento">Mantenimiento</option>
                                                </select>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-primary"
                                                        @onclick="async () => await AsignarPersonaIndividual(persona)"
                                                        disabled="@asignandoPersonal">
                                                    <i class="fas fa-user-plus"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="mt-3 d-flex justify-content-between">
                            <span class="text-muted">
                                Disponibles: @personalDisponible.Count | 
                                Seleccionados: @personalSeleccionadoIds.Count(kv => kv.Value)
                            </span>

                            <div class="btn-group">
                                <button class="btn btn-primary"
                                        @onclick="AsignarPersonalMultiple"
                                        disabled="@(asignandoPersonal || !personalSeleccionadoIds.Any(kv => kv.Value))">
                                    @if (asignandoPersonal)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    <i class="fas fa-user-plus me-2"></i>
                                    Asignar (@personalSeleccionadoIds.Count(kv => kv.Value))
                                </button>
                                <button class="btn btn-secondary" @onclick="CerrarModalAsignar" disabled="@asignandoPersonal">
                                    Cancelar
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int TurnoId { get; set; }

    private TurnoDto? turno = null;
    private List<PersonalTurnoDto> personalTurno = new();
    private List<ConsumoBolsasDTO> consumosBolsas = new();
    private List<ProveedorBolsaDTO> proveedores = new();
    private ParadaDto? paradaActiva;

    private bool cargando = true;
    private bool mostrarModalConsumo = false;
    private bool guardando = false;
    private bool iniciandoParada = false;
    private string errorParada = "";

    // ✅ Variables para modal de asignar personal
    private bool mostrarModalAsignarPersonal = false;
    private List<PersonalDto> personalDisponible = new();
    private Dictionary<int, bool> personalSeleccionadoIds = new();
    private Dictionary<int, string> rolesTurnoSeleccionados = new();
    private bool cargandoPersonalDisponible = false;
    private bool asignandoPersonal = false;
    private string mensajeErrorAsignacion = "";

    private ConsumoBolsasCreateDTO nuevoConsumo = new();
    private CreateParadaDto nuevaParada = new();

    protected override async Task OnParametersSetAsync()
    {
        if (TurnoId > 0)
        {
            await CargarDetalleTurno();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarParadaActiva();
        InicializarNuevaParada();
    }

    private void InicializarNuevaParada()
    {
        nuevaParada = new CreateParadaDto
        {
            TurnoProduccionID = TurnoId,
            FechaHoraInicio = DateTime.Now,
            Tipo = "",
            Motivo = "",
            Descripcion = ""
        };
    }

    private async Task CargarDetalleTurno()
    {
        cargando = true;
        StateHasChanged();

        try
        {
            turno = await TurnoService.GetTurnoByIdAsync(TurnoId);
            if (turno != null)
            {
                personalTurno = await TurnoService.GetPersonalTurnoAsync(TurnoId);
                consumosBolsas = await ConsumoBolsasService.GetConsumosByTurnoAsync(TurnoId);
                proveedores = await ConsumoBolsasService.GetProveedoresAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, $"Error al cargar detalle del turno {TurnoId}");
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private async Task CargarParadaActiva()
    {
        var paradas = await TurnoService.GetParadasTurnoAsync(TurnoId);
        paradaActiva = paradas.FirstOrDefault(p => !p.FechaHoraFin.HasValue);
    }

    // ==================== MÉTODOS DE ASIGNACIÓN DE PERSONAL ====================
    
    private async Task AbrirModalAsignarPersonal()
    {
        try
        {
            mensajeErrorAsignacion = "";
            personalSeleccionadoIds.Clear();
            rolesTurnoSeleccionados.Clear();
            cargandoPersonalDisponible = true;
            mostrarModalAsignarPersonal = true;
            StateHasChanged();

            var todoElPersonal = await PersonalService.GetPersonalAsync();
            var personalActivo = todoElPersonal?.Where(p => p.Activo).ToList() ?? new List<PersonalDto>();
            var idsAsignados = personalTurno?.Select(p => p.PersonalID).ToList() ?? new List<int>();

            personalDisponible = personalActivo
                .Where(p => !idsAsignados.Contains(p.PersonalID))
                .OrderBy(p => p.Nombre)
                .ToList();

            foreach (var p in personalDisponible)
            {
                personalSeleccionadoIds[p.PersonalID] = false;
                rolesTurnoSeleccionados[p.PersonalID] = p.Rol;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al cargar personal disponible");
            mensajeErrorAsignacion = $"Error: {ex.Message}";
        }
        finally
        {
            cargandoPersonalDisponible = false;
            StateHasChanged();
        }
    }

    private void CerrarModalAsignar()
    {
        if (!asignandoPersonal)
        {
            mostrarModalAsignarPersonal = false;
            personalDisponible.Clear();
            personalSeleccionadoIds.Clear();
            rolesTurnoSeleccionados.Clear();
            mensajeErrorAsignacion = "";
        }
    }

    private async Task AsignarPersonaIndividual(PersonalDto persona)
    {
        try
        {
            asignandoPersonal = true;
            mensajeErrorAsignacion = "";
            StateHasChanged();

            var rolTurno = rolesTurnoSeleccionados.GetValueOrDefault(persona.PersonalID, persona.Rol);
            var dto = new AsignarPersonalDto
            {
                PersonalId = persona.PersonalID,
                RolTurno = rolTurno
            };

            var success = await TurnoService.AsignarPersonalAsync(TurnoId, dto);

            if (success)
            {
                personalDisponible.Remove(persona);
                await CargarDetalleTurno();
                mensajeErrorAsignacion = $"✅ {persona.Nombre} asignado exitosamente";
            }
            else
            {
                mensajeErrorAsignacion = "❌ Error al asignar personal";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al asignar personal");
            mensajeErrorAsignacion = $"Error: {ex.Message}";
        }
        finally
        {
            asignandoPersonal = false;
            StateHasChanged();
        }
    }

    private async Task AsignarPersonalMultiple()
    {
        try
        {
            asignandoPersonal = true;
            StateHasChanged();

            var seleccionados = personalSeleccionadoIds.Where(kv => kv.Value).Select(kv => kv.Key).ToList();
            int exitosos = 0;

            foreach (var personalId in seleccionados)
            {
                var persona = personalDisponible.FirstOrDefault(p => p.PersonalID == personalId);
                if (persona == null) continue;

                var dto = new AsignarPersonalDto
                {
                    PersonalId = personalId,
                    RolTurno = rolesTurnoSeleccionados.GetValueOrDefault(personalId, persona.Rol)
                };

                if (await TurnoService.AsignarPersonalAsync(TurnoId, dto))
                {
                    exitosos++;
                }
            }

            if (exitosos > 0)
            {
                await CargarDetalleTurno();
                CerrarModalAsignar();
            }
        }
        finally
        {
            asignandoPersonal = false;
            StateHasChanged();
        }
    }

