@page "/trazabilidad"
@using CementoTrazabilidad.Shared.DTOs
@using CementoTrazabilidad.Blazor.Services
@inject CementoTrazabilidad.Blazor.Services.ILoteService LoteService

<PageTitle>Consulta de Trazabilidad</PageTitle>

<div class="container py-4">
    <h3><i class="fas fa-search me-2"></i>Consulta de Trazabilidad</h3>
    <p class="text-muted">Ingresa la fecha/hora impresa en la bolsa para rastrear su origen</p>

    <div class="card mt-4">
        <div class="card-body">
            <EditForm Model="@consulta" OnValidSubmit="Buscar">
                <DataAnnotationsValidator />

                <div class="row">
                    <div class="col-md-4">
                        <label class="form-label">Fecha impresa en la bolsa</label>
                        <InputDate @bind-Value="consulta.FechaHoraImpresa" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Hora impresa</label>
                        <InputTime @bind-value="horaImpresa" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Tolerancia (min)</label>
                        <InputNumber @bind-Value="consulta.ToleranciaMinutos" class="form-control" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-search me-2"></i>Buscar
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>

    @if (resultado != null)
    {
        @if (resultado.Encontrado)
        {
            <div class="card mt-4 border-success">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-check-circle me-2"></i>Trazabilidad Encontrada
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Información del Lote</h6>
                            <table class="table table-sm">
                                <tr>
                                    <th>Número de Lote:</th>
                                    <td><strong>@resultado.Lote?.NumeroLote</strong></td>
                                </tr>
                                <tr>
                                    <th>Rango Producción:</th>
                                    <td>
                                        @resultado.Lote?.FechaHoraInicio.ToString("dd/MM/yyyy HH:mm") - 
                                        @(resultado.Lote?.FechaHoraFin != null 
                                            ? resultado.Lote.FechaHoraFin.Value.ToString("HH:mm") 
                                            : string.Empty)
                                    </td>
                                </tr>
                                <tr>
                                    <th>Cantidad del Lote:</th>
                                    <td>@resultado.Lote?.CantidadBolsas bolsas</td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <h6>Información del Turno</h6>
                            <table class="table table-sm">
                                <tr>
                                    <th>Turno:</th>
                                    <td>@resultado.TurnoDescripcion</td>
                                </tr>
                                <tr>
                                    <th>Personal:</th>
                                    <td>@string.Join(", ", resultado.PersonalTurno)</td>
                                </tr>
                                <tr>
                                    <th>Máquina:</th>
                                    <td>@resultado.MaquinaUtilizada</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-warning mt-4">
                <i class="fas fa-exclamation-triangle me-2"></i>
                No se encontró información de trazabilidad para esa fecha/hora.
            </div>
        }
    }

    @if (!string.IsNullOrEmpty(mensajeError))
    {
        <div class="alert alert-danger mt-3">
            <i class="fas fa-times-circle me-2"></i>
            @mensajeError
        </div>
    }
</div>

@code {
    private ConsultaTrazabilidadDto consulta = new() { ToleranciaMinutos = 5 };
    private TimeSpan horaImpresa = TimeSpan.FromHours(12);
    private ResultadoTrazabilidadDto? resultado;
    private string mensajeError;

    private async Task Buscar()
    {
        if (consulta.FechaHoraImpresa == null)
        {
            mensajeError = "La fecha impresa en la bolsa es requerida.";
            return;
        }

        consulta.FechaHoraImpresa = consulta.FechaHoraImpresa.Date + horaImpresa;
        resultado = await LoteService.BuscarTrazabilidadAsync(consulta);

        if (resultado == null || !resultado.Encontrado)
        {
            mensajeError = "No se encontró información de trazabilidad para la fecha/hora proporcionada.";
        }
        else
        {
            mensajeError = string.Empty;
        }
    }
}